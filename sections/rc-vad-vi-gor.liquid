{% comment %}
  reCarpet Vad vi gör — Services overview + detail sections
  Used on /pages/vad-vi-gor (Tjänster page)
{% endcomment %}

<style>
  /* Timeline navigation */
  .rc-services-nav {
    background: var(--rc-green, #1E4433);
    padding: 40px 48px;
    position: sticky;
    top: 0;
    z-index: 50;
    overflow-x: auto;
    overflow-y: hidden;
  }
  .rc-services-nav__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    gap: 0;
    align-items: center;
    justify-content: space-between;
    position: relative;
    min-height: 120px;
  }
  /* Timeline line */
  .rc-services-nav__inner::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-50%);
    z-index: 1;
  }
  /* Timeline node wrapper */
  .rc-services-nav__node {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex: 1;
    text-align: center;
  }
  /* Node circle */
  .rc-services-nav__node-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 600;
    color: #fff;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    flex-shrink: 0;
  }
  .rc-services-nav__node.active .rc-services-nav__node-circle {
    background: rgba(255, 255, 255, 0.3);
    border-color: #fff;
    transform: scale(1.1);
  }
  .rc-services-nav__node:hover .rc-services-nav__node-circle {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.05);
  }
  /* Node text/label */
  .rc-services-nav__node-label {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    white-space: nowrap;
    transition: color 0.3s ease;
    text-decoration: none;
  }
  .rc-services-nav__node.active .rc-services-nav__node-label {
    color: #fff;
  }
  .rc-services-nav__node:hover .rc-services-nav__node-label {
    color: #fff;
  }

  /* Service detail section */
  .rc-service-detail {
    padding: var(--rc-section-pad, 80px) 0;
  }
  .rc-service-detail:nth-child(even) { background: var(--rc-cream, #F6F6F6); }
  .rc-service-detail:nth-child(odd) { background: var(--rc-white, #fff); }
  .rc-service-detail__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .rc-service-detail--reverse .rc-service-detail__text { order: 2; }
  .rc-service-detail--reverse .rc-service-detail__image { order: 1; }
  .rc-service-detail__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rc-text-muted);
    margin-bottom: 8px;
  }
  .rc-service-detail__heading {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 500;
    color: var(--rc-text);
    margin: 0 0 16px;
  }
  .rc-service-detail__body { font-size: 16px; line-height: 1.75; color: var(--rc-text-muted); margin: 0 0 12px; }
  .rc-service-detail__list {
    list-style: none;
    padding: 0;
    margin: 16px 0 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .rc-service-detail__list li {
    font-size: 15px;
    color: var(--rc-text-muted);
    padding-left: 20px;
    position: relative;
  }
  .rc-service-detail__list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--rc-green);
    font-weight: 700;
  }
  .rc-service-detail__image { border-radius: 8px; overflow: hidden; aspect-ratio: 4/3; }
  .rc-service-detail__image img { width: 100%; height: 100%; object-fit: cover; }

  @media (max-width: 900px) {
    .rc-service-detail__inner { grid-template-columns: 1fr; gap: 32px; }
    .rc-service-detail--reverse .rc-service-detail__text,
    .rc-service-detail--reverse .rc-service-detail__image { order: unset; }
    .rc-service-detail__inner { padding: 0 20px; }
    .rc-services-nav {
      padding: 32px 20px;
    }
    .rc-services-nav__inner {
      min-height: 100px;
    }
    .rc-services-nav__node-circle {
      width: 40px;
      height: 40px;
      font-size: 14px;
    }
    .rc-services-nav__node-label {
      font-size: 12px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const nav = document.querySelector('.rc-services-nav');
    const nodes = document.querySelectorAll('.rc-services-nav__node');
    const sections = document.querySelectorAll('[data-service-section]');

    // Smooth scroll on node click
    nodes.forEach(node => {
      node.addEventListener('click', function(e) {
        e.preventDefault();
        const anchor = this.dataset.anchor;
        const target = document.querySelector(`[data-service-section="${anchor}"]`);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Intersection Observer for active state tracking
    const observerOptions = {
      root: null,
      rootMargin: '-25% 0px -75% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(entry => {
        const anchor = entry.target.dataset.serviceSection;
        const node = document.querySelector(`[data-anchor="${anchor}"]`);
        
        if (entry.isIntersecting) {
          // Remove active from all nodes
          nodes.forEach(n => n.classList.remove('active'));
          // Add active to current node
          if (node) {
            node.classList.add('active');
          }
        }
      });
    }, observerOptions);

    sections.forEach(section => {
      observer.observe(section);
    });
  });
</script>

<!-- Timeline navigation -->
<nav class="rc-services-nav" aria-label="Tjänster">
  <div class="rc-services-nav__inner">
    <div class="rc-services-nav__node active" data-anchor="inventering" role="button" tabindex="0">
      <div class="rc-services-nav__node-circle">1</div>
      <a href="#inventering" class="rc-services-nav__node-label">Inventering</a>
    </div>
    <div class="rc-services-nav__node" data-anchor="demontering" role="button" tabindex="0">
      <div class="rc-services-nav__node-circle">2</div>
      <a href="#demontering" class="rc-services-nav__node-label">Demontering</a>
    </div>
    <div class="rc-services-nav__node" data-anchor="formedling" role="button" tabindex="0">
      <div class="rc-services-nav__node-circle">3</div>
      <a href="#formedling" class="rc-services-nav__node-label">Förmedling</a>
    </div>
    <div class="rc-services-nav__node" data-anchor="montering" role="button" tabindex="0">
      <div class="rc-services-nav__node-circle">4</div>
      <a href="#montering" class="rc-services-nav__node-label">Montering</a>
    </div>
    <div class="rc-services-nav__node" data-anchor="service" role="button" tabindex="0">
      <div class="rc-services-nav__node-circle">5</div>
      <a href="#service" class="rc-services-nav__node-label">Service & underhåll</a>
    </div>
    <div class="rc-services-nav__node" data-anchor="internt-aterbruk" role="button" tabindex="0">
      <div class="rc-services-nav__node-circle">6</div>
      <a href="#internt-aterbruk" class="rc-services-nav__node-label">Internt återbruk</a>
    </div>
  </div>
</nav>

<!-- Service detail blocks -->
{%- for block in section.blocks -%}
  {%- assign is_reverse = forloop.index | modulo: 2 -%}
  <section
    class="rc-service-detail{% if is_reverse == 0 %} rc-service-detail--reverse{% endif %}"
    id="{{ block.settings.anchor | default: block.settings.title | downcase | replace: ' ', '-' }}"
    data-service-section="{{ block.settings.anchor | default: block.settings.title | downcase | replace: ' ', '-' }}"
  >
    <div class="rc-service-detail__inner">
      <div class="rc-service-detail__text">
        {%- if block.settings.eyebrow != blank -%}
          <p class="rc-service-detail__eyebrow">{{ block.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="rc-service-detail__heading">{{ block.settings.title }}</h2>
        <p class="rc-service-detail__body">{{ block.settings.body }}</p>
        {%- if block.settings.list != blank -%}
          <ul class="rc-service-detail__list">
            {%- assign items = block.settings.list | newline_to_br | split: '<br />' -%}
            {%- for item in items -%}
              {%- if item != blank -%}<li>{{ item | strip }}</li>{%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- if block.settings.btn_label != blank -%}
          <a href="{{ block.settings.btn_url | default: '/pages/kontakta-oss' }}" class="rc-btn rc-btn--outline">{{ block.settings.btn_label }}</a>
        {%- endif -%}
      </div>
      <div class="rc-service-detail__image">
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title }}" loading="lazy">
        {%- else -%}
          <div style="background:var(--rc-cream-alt);height:100%;min-height:260px;"></div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endfor -%}

