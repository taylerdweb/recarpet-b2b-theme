<div class="rc-quote" style="background-color: {{ section.settings.background_color | default: 'var(--rc-cream, #F6F6F6)' }}">
  <div class="rc-quote__container">
    <div class="rc-quote__mark">"</div>
    <blockquote class="rc-quote__text">
      {{ section.settings.quote_text }}
    </blockquote>
    <div class="rc-quote__attribution">
      <div class="rc-quote__author">{{ section.settings.author_name }}</div>
      <div class="rc-quote__title">{{ section.settings.author_title }}</div>
    </div>
  </div>
</div>

<style>
  :root {
    --rc-cream: #F6F6F6;
    --rc-green: #1E4433;
    --rc-text: #1a1a1a;
    --rc-muted: #666666;
  }

  .rc-quote {
    width: 100%;
    padding: 80px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rc-quote__container {
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  .rc-quote__mark {
    font-size: clamp(60px, 10vw, 120px);
    line-height: 1;
    font-weight: 300;
    color: var(--rc-green);
    margin-bottom: 20px;
    display: block;
    font-family: Georgia, serif;
  }

  .rc-quote__text {
    font-size: clamp(20px, 2.5vw, 28px);
    font-style: italic;
    font-weight: 500;
    line-height: 1.6;
    margin: 0;
    margin-bottom: 40px;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: inherit;
  }

  .rc-quote__attribution {
    margin-top: 30px;
  }

  .rc-quote__author {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--rc-text);
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .rc-quote__title {
    font-size: 14px;
    font-weight: 400;
    color: var(--rc-muted);
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* Dark text on green background */
  .rc-quote[style*="--rc-green"],
  .rc-quote[style*="#1E4433"] {
    color: white;
  }

  .rc-quote[style*="--rc-green"] .rc-quote__mark,
  .rc-quote[style*="#1E4433"] .rc-quote__mark {
    color: white;
    opacity: 0.8;
  }

  .rc-quote[style*="--rc-green"] .rc-quote__author,
  .rc-quote[style*="#1E4433"] .rc-quote__author {
    color: white;
  }

  .rc-quote[style*="--rc-green"] .rc-quote__title,
  .rc-quote[style*="#1E4433"] .rc-quote__title {
    color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 768px) {
    .rc-quote {
      padding: 60px 20px;
    }

    .rc-quote__mark {
      margin-bottom: 16px;
    }

    .rc-quote__text {
      margin-bottom: 32px;
    }
  }
</style>

{% schema %}
{
  "name": "RC Quote",
  "settings": [
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote Text",
      "placeholder": "Enter the testimonial or quote here"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author Name",
      "placeholder": "e.g., John Smith"
    },
    {
      "type": "text",
      "id": "author_title",
      "label": "Author Title",
      "placeholder": "e.g., CEO, Acme Corp"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": [
        {
          "value": "var(--rc-cream, #F6F6F6)",
          "label": "Cream"
        },
        {
          "value": "#FFFFFF",
          "label": "White"
        },
        {
          "value": "var(--rc-green, #1E4433)",
          "label": "Green"
        }
      ],
      "default": "var(--rc-cream, #F6F6F6)"
    }
  ],
  "presets": [
    {
      "name": "RC Quote"
    }
  ]
}
{% endschema %}
