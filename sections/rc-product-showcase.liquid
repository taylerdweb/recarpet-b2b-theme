{% comment %}
  reCarpet Product Showcase
  Uses the standard card-product snippet in a clean white-background grid
{% endcomment %}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

<style>
  .rc-product-showcase {
    background: #fff;
    padding: var(--rc-section-md) 0;
  }
  .rc-product-showcase__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
  }
  h2.rc-product-showcase__heading {
    text-align: center;
    font-family: var(--recarpet-dm-sans);
    font-size: clamp(1.75rem, 3.5vw, var(--rc-h3));
    font-weight: 500;
    line-height: 120%;
    margin: 0 0 3rem;
    color: var(--base-color-brand--rc-off-black);
  }
  .rc-product-showcase__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .rc-product-showcase__viewall {
    text-align: center;
    margin-top: 3rem;
  }
  .rc-product-showcase__viewall a {
    font-family: var(--recarpet-dm-sans);
    font-size: 1rem;
    font-weight: 500;
    color: #fff;
    background: var(--base-color-brand--rc-off-black);
    padding: 0.85rem 2.5rem;
    border-radius: var(--rc-radius);
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s;
  }
  .rc-product-showcase__viewall a:hover {
    opacity: 0.85;
  }
  @media (max-width: 989px) {
    .rc-product-showcase__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .rc-product-showcase__inner { padding: 0 1.25rem; }
  }
</style>

{%- assign showcase_collection = section.settings.collection -%}
{%- assign products_to_show = section.settings.products_to_show | default: 4 -%}

<section class="rc-product-showcase">
  <div class="rc-product-showcase__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="rc-product-showcase__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="rc-product-showcase__grid">
      {%- if showcase_collection != blank -%}
        {%- for product in showcase_collection.products limit: products_to_show -%}
          {%- render 'card-product',
            card_product: product,
            media_aspect_ratio: 'square',
            image_shape: 'default',
            show_secondary_image: false,
            show_vendor: false,
            show_rating: false,
            lazy_load: true,
            skip_styles: true,
            section_id: section.id,
            quick_add: 'none'
          -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          {%- render 'card-product',
            media_aspect_ratio: 'square',
            image_shape: 'default',
            show_vendor: false,
            show_rating: false,
            lazy_load: true,
            skip_styles: true,
            section_id: section.id
          -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and showcase_collection != blank -%}
      <div class="rc-product-showcase__viewall">
        <a href="{{ showcase_collection.url }}">{{ section.settings.view_all_text | default: 'Se alla produkter' }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "reCarpet Produkter",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Rubrik",
      "default": "Utvalda produkter"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Antal produkter"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Visa 'Se alla' knapp",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Knapptext",
      "default": "Se alla produkter"
    }
  ],
  "presets": [
    {
      "name": "reCarpet Produkter"
    }
  ]
}
{% endschema %}
