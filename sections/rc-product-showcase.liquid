{% comment %}
  reCarpet Product Showcase
  Same card grid design as customer cards but pulling real products from a collection
{% endcomment %}

<style>
  .rc-product-showcase {
    background: #fff;
    padding: var(--rc-section-md) 0;
  }
  .rc-product-showcase__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
  }
  h2.rc-product-showcase__heading {
    text-align: center;
    font-family: var(--recarpet-dm-sans);
    font-size: clamp(1.75rem, 3.5vw, var(--rc-h3));
    font-weight: 500;
    line-height: 120%;
    margin: 0 0 5rem;
    color: var(--base-color-brand--rc-off-black);
  }
  .rc-product-showcase__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .rc-pcard {
    background: transparent;
    border-radius: var(--rc-radius);
    overflow: hidden;
    text-decoration: none;
    color: var(--rc-text);
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .rc-pcard:hover {
    color: var(--rc-text);
  }
  .rc-pcard__image {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #f5f5f0;
  }
  .rc-pcard__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .rc-pcard:hover .rc-pcard__image img {
    transform: scale(1.04);
  }
  .rc-pcard__body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    text-align: center;
  }
  .rc-pcard__title {
    font-family: var(--recarpet-dm-sans);
    font-size: var(--rc-h5);
    font-weight: 700;
    line-height: 140%;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 0.5rem;
    text-align: center;
  }
  .rc-pcard__vendor {
    font-family: var(--recarpet-dm-sans);
    font-size: 0.85rem;
    color: #888;
    margin: 0 0 0.5rem;
    text-align: center;
  }
  .rc-pcard__text {
    font-family: var(--recarpet-dm-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 1rem;
    flex: 1;
    text-align: center;
  }
  .rc-pcard__link {
    font-size: var(--rc-text-sm);
    font-weight: 500;
    color: var(--rc-green);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    justify-content: center;
  }
  .rc-pcard__link::after { content: ' →'; }
  .rc-product-showcase__viewall {
    text-align: center;
    margin-top: 3rem;
  }
  .rc-product-showcase__viewall a {
    font-family: var(--recarpet-dm-sans);
    font-size: 1rem;
    font-weight: 500;
    color: #fff;
    background: var(--base-color-brand--rc-off-black);
    padding: 0.85rem 2.5rem;
    border-radius: var(--rc-radius);
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.2s;
  }
  .rc-product-showcase__viewall a:hover {
    opacity: 0.85;
  }
  @media (max-width: 900px) {
    .rc-product-showcase__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .rc-product-showcase__grid { grid-template-columns: 1fr; }
    .rc-product-showcase__inner { padding: 0 1.25rem; }
  }
</style>

{%- assign showcase_collection = section.settings.collection -%}
{%- assign products_to_show = section.settings.products_to_show | default: 4 -%}

<section class="rc-product-showcase">
  <div class="rc-product-showcase__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="rc-product-showcase__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="rc-product-showcase__grid">
      {%- if showcase_collection != blank -%}
        {%- for product in showcase_collection.products limit: products_to_show -%}
          <a href="{{ product.url }}" class="rc-pcard">
            <div class="rc-pcard__image">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | default: product.title }}"
                  loading="lazy"
                  width="600"
                  height="450"
                >
              {%- endif -%}
            </div>
            <div class="rc-pcard__body">
              <h3 class="rc-pcard__title">{{ product.title }}</h3>
              {%- if section.settings.show_vendor and product.vendor != blank -%}
                <p class="rc-pcard__vendor">{{ product.vendor }}</p>
              {%- endif -%}
              <span class="rc-pcard__link">{{ section.settings.link_text | default: 'Se produkt' }}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          <div class="rc-pcard">
            <div class="rc-pcard__image">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="rc-pcard__body">
              <h3 class="rc-pcard__title">Produktnamn</h3>
              <span class="rc-pcard__link">{{ section.settings.link_text | default: 'Se produkt' }}</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and showcase_collection != blank -%}
      <div class="rc-product-showcase__viewall">
        <a href="{{ showcase_collection.url }}">{{ section.settings.view_all_text | default: 'Se alla produkter' }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "reCarpet Produkter",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Rubrik",
      "default": "Utvalda produkter"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Antal produkter"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Visa tillverkare",
      "default": false
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Länktext",
      "default": "Se produkt"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Visa 'Se alla' knapp",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Knapptext",
      "default": "Se alla produkter"
    }
  ],
  "presets": [
    {
      "name": "reCarpet Produkter"
    }
  ]
}
{% endschema %}
