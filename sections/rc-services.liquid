{% comment %}
  reCarpet Services Section
  "Gör skillnad med hållbara golvlösningar!"
  Timeline/alternating layout: Inventering, Demontering, Förmedling, Montering, Service & Underhåll, Internt återbruk
  Scroll indicator: CSS-only sticky progress line (matches Webflow timeline13 pattern)
{% endcomment %}

<style>
  .rc-services {
    background: var(--rc-cream-alt);
    padding: var(--rc-section-md) 0;
  }
  .rc-services__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
  }
  .rc-services__header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .rc-services__eyebrow {
    font-size: var(--rc-text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rc-text-muted);
    margin-bottom: 0.75rem;
  }
  .rc-services .rc-services__heading {
    font-family: var(--recarpet-dm-sans);
    font-size: clamp(1.75rem, 4vw, var(--rc-h2));
    font-weight: 500;
    line-height: 120%;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 auto 2rem;
    max-width: 50rem;
  }
  .rc-services__intro {
    font-family: var(--recarpet-dm-sans);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--base-color-brand--rc-off-black);
    max-width: 40rem;
    margin: 0 auto 1.75rem;
  }

  /* ===== Timeline container ===== */
  .rc-services__timeline {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5rem;
    position: relative;
  }

  /* ===== Progress track (centered absolute column) ===== */
  .rc-services__progress {
    position: absolute;
    left: calc(50% - 1rem);
    top: 0;
    bottom: 0;
    width: 2rem;
    /* No transform! transform creates a new containing block and breaks position:sticky */
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
    z-index: 1;
  }

  /* Grey background line — flex child fills full height of progress wrapper */
  .rc-services__track {
    width: 3px;
    height: 100%;
    background: var(--base-color-neutral--neutral-lighter);
  }

  /* Override Dawn base.css: div:empty { display:none } — these are decorative elements */
  .rc-services__progress-line,
  .rc-services__progress-cover,
  .rc-services__fade-top,
  .rc-services__fade-bottom {
    display: block !important;
  }

  /* Black progress line — sticky at viewport top, 50vh tall, offset by -50vh
     so the visible bottom edge sits at viewport center */
  .rc-services__progress-line {
    background: var(--base-color-neutral--black);
    width: 3px;
    height: 50vh;
    margin-top: -50vh;
    position: sticky;
    top: 0;
    z-index: 1;
  }

  /* Cover: hides the progress line above the timeline start.
     Same bg as section so the line appears to "start" at the timeline top */
  .rc-services__progress-cover {
    background: var(--rc-cream-alt);
    width: 100%;
    height: 50vh;
    position: absolute;
    top: -50vh;
    z-index: 2;
  }

  /* Fade overlay top — blends the line start into the background */
  .rc-services__fade-top {
    position: absolute;
    top: 0;
    width: 4px;
    height: 4rem;
    background: linear-gradient(180deg, var(--rc-cream-alt), transparent);
    z-index: 3;
  }

  /* Fade overlay bottom — blends the line end into the background */
  .rc-services__fade-bottom {
    position: absolute;
    bottom: 0;
    width: 4px;
    height: 4rem;
    background: linear-gradient(0deg, var(--rc-cream-alt), transparent);
    z-index: 3;
  }

  /* ===== Timeline row ===== */
  .rc-services__item {
    display: grid;
    grid-template-columns: 1fr max-content 1fr;
    align-items: center;
    gap: 3rem;
    position: relative;
    z-index: 2;
  }
  .rc-services__item--reverse .rc-services__item-text { order: -1; }

  /* ===== Center dot — always sage green with ring ===== */
  .rc-services__dot {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 2rem;
  }
  .rc-services__dot-inner {
    display: block !important; /* Override Dawn base.css div:empty { display:none } */
    width: 0.9375rem;
    height: 0.9375rem;
    border-radius: 50%;
    background: var(--rc-sage);
    box-shadow: 0 0 0 8px var(--rc-cream-alt);
    z-index: 2;
    position: relative;
  }

  /* ===== Image & text ===== */
  .rc-services__item-image {
    border-radius: var(--rc-radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .rc-services__item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .rc-services__item-text {
    padding: 0;
  }
  .rc-services__item--reverse .rc-services__item-text {
    text-align: right;
    padding: 0;
  }
  .rc-services__item-eyebrow {
    font-size: var(--rc-text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rc-text-muted);
    margin-bottom: 0.75rem;
  }
  .rc-services .rc-services__item-title {
    font-family: var(--recarpet-dm-sans);
    font-size: clamp(1.75rem, 3vw, var(--rc-h3));
    font-weight: 500;
    line-height: 120%;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 1rem;
  }
  .rc-services__item-body {
    font-family: var(--recarpet-dm-sans);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 1.5rem;
  }
  .rc-services__item-link {
    font-family: var(--recarpet-dm-sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--base-color-brand--rc-off-black);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .rc-services__item-link:hover { text-decoration: underline; }
  .rc-services__item-link::after { content: ' \203A'; margin-left: 0.25rem; }
  .rc-services__item--reverse .rc-services__item-link::before { content: '\2039 '; margin-right: 0.25rem; }
  .rc-services__item--reverse .rc-services__item-link::after { content: ''; margin: 0; }

  /* ===== Tablet (991px) ===== */
  @media (max-width: 991px) {
    .rc-services__item {
      gap: 2rem;
    }
  }

  /* ===== Mobile (767px) ===== */
  @media (max-width: 767px) {
    .rc-services__timeline {
      gap: 4rem;
    }
    .rc-services__progress { display: none; }
    .rc-services__item {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .rc-services__dot { display: none; }
    .rc-services__item-text,
    .rc-services__item--reverse .rc-services__item-text {
      padding: 0;
      text-align: left;
      order: unset;
    }
    .rc-services__item--reverse .rc-services__item-link::before { content: ''; margin: 0; }
    .rc-services__item--reverse .rc-services__item-link::after { content: ' \203A'; margin-left: 0.25rem; }
    .rc-services__inner { padding: 0 1.25rem; }
  }
</style>

<section class="rc-services">
  <div class="rc-services__inner">
    <div class="rc-services__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rc-services__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="rc-services__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.intro != blank -%}
        <p class="rc-services__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url }}" class="rc-btn rc-btn--outline" style="border: 1px solid;">{{ section.settings.btn_label }}</a>
      {%- endif -%}
    </div>

    <div class="rc-services__timeline">
      {%- comment -%}Progress track — CSS-only sticky scroll indicator{%- endcomment -%}
      <div class="rc-services__progress" aria-hidden="true">
        <div class="rc-services__progress-cover"></div>
        <div class="rc-services__fade-top"></div>
        <div class="rc-services__track">
          <div class="rc-services__progress-line"></div>
        </div>
        <div class="rc-services__fade-bottom"></div>
      </div>

      {%- for block in section.blocks -%}
        {%- assign is_reverse = forloop.index | modulo: 2 -%}
        <div class="rc-services__item{% if is_reverse == 0 %} rc-services__item--reverse{% endif %}">
          {%- if is_reverse == 1 -%}
            {%- comment %}Image left{% endcomment -%}
            <div class="rc-services__item-image">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" loading="lazy">
              {%- else -%}
                <div style="background:var(--rc-cream);height:100%;min-height:240px;"></div>
              {%- endif -%}
            </div>
            <div class="rc-services__dot"><div class="rc-services__dot-inner"></div></div>
            <div class="rc-services__item-text">
              <p class="rc-services__item-eyebrow">{{ block.settings.eyebrow }}</p>
              <h3 class="rc-services__item-title">{{ block.settings.title }}</h3>
              <p class="rc-services__item-body">{{ block.settings.body }}</p>
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" class="rc-services__item-link">Läs mer om {{ block.settings.title }}</a>
              {%- endif -%}
            </div>
          {%- else -%}
            {%- comment %}Text left, image right{% endcomment -%}
            <div class="rc-services__item-text">
              <p class="rc-services__item-eyebrow">{{ block.settings.eyebrow }}</p>
              <h3 class="rc-services__item-title">{{ block.settings.title }}</h3>
              <p class="rc-services__item-body">{{ block.settings.body }}</p>
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" class="rc-services__item-link">Läs mer om {{ block.settings.title }}</a>
              {%- endif -%}
            </div>
            <div class="rc-services__dot"><div class="rc-services__dot-inner"></div></div>
            <div class="rc-services__item-image">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" loading="lazy">
              {%- else -%}
                <div style="background:var(--rc-cream);height:100%;min-height:240px;"></div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

