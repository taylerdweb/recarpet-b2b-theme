{% comment %}
  reCarpet Services Section
  "Gör skillnad med hållbara golvlösningar!"
  Timeline/alternating layout: Inventering, Demontering, Förmedling, Montering, Service & Underhåll, Internt återbruk
{% endcomment %}

<style>
  .rc-services {
    background: var(--rc-cream);
    padding: var(--rc-section-md) 0;
  }
  .rc-services__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
  }
  .rc-services__header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .rc-services__eyebrow {
    font-size: var(--rc-text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rc-text-muted);
    margin-bottom: 0.75rem;
  }
  .rc-services__heading {
    font-family: var(--recarpet-dm-sans);
    font-size: clamp(1.75rem, 4vw, var(--rc-h2));
    font-weight: 500;
    line-height: 120%;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 1.25rem;
    max-width: 50rem;
    margin-left: auto;
    margin-right: auto;
  }
  .rc-services__intro {
    font-family: var(--recarpet-dm-sans);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--base-color-brand--rc-off-black);
    max-width: 40rem;
    margin: 0 auto 1.75rem;
  }

  /* Timeline row: alternating image + text */
  .rc-services__timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }
  /* Vertical line (grey background track) */
  .rc-services__timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--base-color-neutral--neutral-lighter);
    transform: translateX(-50%);
  }
  .rc-services__item {
    display: grid;
    grid-template-columns: 1fr 5rem 1fr;
    align-items: center;
    gap: 0;
    padding: 5rem 0;
  }
  .rc-services__item--reverse .rc-services__item-text { order: -1; }

  /* Center dot */
  .rc-services__dot {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .rc-services__dot-inner {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: var(--base-color-neutral--neutral-lighter);
    border: none;
    box-shadow: none;
    transition: background 0.3s, width 0.3s, height 0.3s, box-shadow 0.3s;
  }
  /* Dot passed by scroll progress → brand green */
  .rc-services__dot-inner.is-passed {
    background: var(--base-color-brand--rc-re-green);
  }
  /* Currently active dot → larger, green with ring */
  .rc-services__dot-inner.is-active {
    width: 1rem;
    height: 1rem;
    background: var(--base-color-brand--rc-re-green);
    box-shadow: 0 0 0 3px var(--rc-cream), 0 0 0 4px var(--base-color-brand--rc-re-green);
  }

  .rc-services__item-image {
    border-radius: var(--rc-radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .rc-services__item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .rc-services__item-text {
    padding: 0 2.5rem;
  }
  .rc-services__item--reverse .rc-services__item-text {
    text-align: right;
    padding: 0 2.5rem;
  }
  .rc-services__item-eyebrow {
    font-size: var(--rc-text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rc-text-muted);
    margin-bottom: 0.75rem;
  }
  .rc-services__item-title {
    font-family: var(--recarpet-dm-sans);
    font-size: clamp(1.75rem, 3vw, var(--rc-h3));
    font-weight: 500;
    line-height: 120%;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 1rem;
  }
  .rc-services__item-body {
    font-family: var(--recarpet-dm-sans);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 1.5rem;
  }
  .rc-services__item-link {
    font-family: var(--recarpet-dm-sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--base-color-brand--rc-off-black);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .rc-services__item-link:hover { text-decoration: underline; }
  .rc-services__item-link::after { content: ' →'; }
  .rc-services__item--reverse .rc-services__item-link::before { content: '← '; }
  .rc-services__item--reverse .rc-services__item-link::after { content: ''; }

  /* Progress line overlay (black fill on scroll) */
  .rc-services__timeline::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    width: 2px;
    height: 0%;
    background: var(--base-color-neutral--black);
    transform: translateX(-50%);
    z-index: 1;
    transition: height 0.1s linear;
  }

  @media (max-width: 900px) {
    .rc-services__timeline::before { display: none; }
    .rc-services__item {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      padding: 2rem 0;
    }
    .rc-services__dot { display: none; }
    .rc-services__item-text,
    .rc-services__item--reverse .rc-services__item-text {
      padding: 0;
      text-align: left;
      order: unset;
    }
    .rc-services__item--reverse .rc-services__item-link::before { content: ''; }
    .rc-services__item--reverse .rc-services__item-link::after { content: ' →'; }
    .rc-services__inner { padding: 0 1.25rem; }
  }
</style>

<section class="rc-services">
  <div class="rc-services__inner">
    <div class="rc-services__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rc-services__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="rc-services__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.intro != blank -%}
        <p class="rc-services__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url }}" class="rc-btn rc-btn--outline" style="border: 1px solid;">{{ section.settings.btn_label }}</a>
      {%- endif -%}
    </div>

    <div class="rc-services__timeline">
      {%- for block in section.blocks -%}
        {%- assign is_reverse = forloop.index | modulo: 2 -%}
        <div class="rc-services__item{% if is_reverse == 0 %} rc-services__item--reverse{% endif %}">
          {%- if is_reverse == 1 -%}
            {%- comment %}Image left{% endcomment -%}
            <div class="rc-services__item-image">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" loading="lazy">
              {%- else -%}
                <div style="background:var(--rc-cream-alt);height:100%;min-height:240px;"></div>
              {%- endif -%}
            </div>
            <div class="rc-services__dot"><div class="rc-services__dot-inner"></div></div>
            <div class="rc-services__item-text">
              <p class="rc-services__item-eyebrow">{{ block.settings.eyebrow }}</p>
              <h3 class="rc-services__item-title">{{ block.settings.title }}</h3>
              <p class="rc-services__item-body">{{ block.settings.body }}</p>
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" class="rc-services__item-link">Läs mer om {{ block.settings.title }}</a>
              {%- endif -%}
            </div>
          {%- else -%}
            {%- comment %}Text left, image right{% endcomment -%}
            <div class="rc-services__item-text">
              <p class="rc-services__item-eyebrow">{{ block.settings.eyebrow }}</p>
              <h3 class="rc-services__item-title">{{ block.settings.title }}</h3>
              <p class="rc-services__item-body">{{ block.settings.body }}</p>
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" class="rc-services__item-link">Läs mer om {{ block.settings.title }}</a>
              {%- endif -%}
            </div>
            <div class="rc-services__dot"><div class="rc-services__dot-inner"></div></div>
            <div class="rc-services__item-image">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}" loading="lazy">
              {%- else -%}
                <div style="background:var(--rc-cream-alt);height:100%;min-height:240px;"></div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const timeline = document.querySelector('.rc-services__timeline');
  const dots = document.querySelectorAll('.rc-services__dot-inner');

  if (!timeline || dots.length === 0) return;

  /* Inject the CSS-variable-driven height rule once */
  const style = document.createElement('style');
  style.textContent = '.rc-services__timeline::after{height:var(--progress,0%)}';
  document.head.appendChild(style);

  function updateProgress() {
    const rect   = timeline.getBoundingClientRect();
    const center = window.innerHeight / 2;

    /* Progress 0→1 as center of viewport travels down the timeline */
    let progress = (center - rect.top) / rect.height;
    progress = Math.max(0, Math.min(1, progress));
    timeline.style.setProperty('--progress', progress * 100 + '%');

    /* Absolute Y of the progress line's bottom edge */
    const progressY = rect.top + rect.height * progress;

    dots.forEach(dot => {
      const dotY = dot.getBoundingClientRect().top + dot.getBoundingClientRect().height / 2;

      dot.classList.remove('is-passed', 'is-active');

      if (progressY >= dotY + 20) {
        /* Line has passed this dot → solid green */
        dot.classList.add('is-passed');
      } else if (progressY >= dotY - 20) {
        /* Line is right at this dot → active (larger, ring) */
        dot.classList.add('is-active');
      }
      /* Otherwise stays grey (default) */
    });
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
});
</script>

