{% comment %}
  reCarpet Hero Section
  Full-bleed hero with headline, subtitle and CTA — centered layout
{% endcomment %}

<style>
  .rc-hero {
    position: relative;
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--base-color-brand--rc-re-green);
    margin-top: -72px;
    padding-top: 72px;
  }
  .rc-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .rc-hero__bg img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
  }
  .rc-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.75) 0%,
      rgba(0,0,0,0.50) 40%,
      rgba(0,0,0,0.35) 100%
    );
    pointer-events: none;
  }
  .rc-hero__content {
    position: relative;
    z-index: 2;
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: var(--rc-section-md) var(--rc-page-padding);
    width: 100%;
    color: var(--base-color-neutral--white);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .rc-hero__eyebrow {
    display: inline-block;
    font-family: var(--recarpet-dm-sans);
    font-size: var(--rc-text-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    margin-bottom: 16px;
  }
  .rc-hero__heading {
    font-family: var(--recarpet-dm-sans);
    font-size: clamp(40px, 5vw, var(--rc-h1));
    font-weight: var(--rc-heading-weight);
    line-height: 1.1;
    color: var(--base-color-neutral--white);
    margin: 0 0 20px;
    max-width: 800px;
  }
  .rc-hero__subtext {
    font-family: var(--recarpet-dm-sans);
    font-size: 32px;
    font-weight: var(--rc-heading-weight);
    line-height: 1.3;
    color: var(--base-color-brand--white);
    max-width: 700px;
    margin: 0 0 36px;
  }
  .rc-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  /* Hero button uses .button class from global styles, override for white outline */
  .rc-hero .rc-btn--outline-white,
  .rc-hero .button.is-hero-outline {
    background: transparent;
    color: var(--base-color-neutral--white);
    border-color: rgba(255,255,255,0.85);
  }
  .rc-hero .rc-btn--outline-white:hover,
  .rc-hero .button.is-hero-outline:hover {
    background: rgba(255,255,255,0.15);
    color: var(--base-color-neutral--white);
  }

  @media (max-width: 991px) {
    .rc-hero__subtext { font-size: 26px; }
  }
  @media (max-width: 767px) {
    .rc-hero__content { padding: var(--rc-section-sm) 20px; }
    .rc-hero { min-height: 500px; }
    .rc-hero__subtext { font-size: 22px; }
  }
</style>

<section class="rc-hero">
  <div class="rc-hero__bg">
    {%- if section.settings.background_image != blank -%}
      {{ section.settings.background_image | image_url: width: 1920 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- endif -%}
  </div>
  <div class="rc-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="rc-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="rc-hero__heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.subtext != blank -%}
      <p class="rc-hero__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    <div class="rc-hero__actions">
      {%- if section.settings.btn1_label != blank -%}
        <a href="{{ section.settings.btn1_url }}" class="rc-btn rc-btn--primary">
          {{ section.settings.btn1_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "reCarpet Hero",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Bakgrundsbild"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bildposition",
      "options": [
        { "value": "center center", "label": "Mitten" },
        { "value": "top center", "label": "Topp" },
        { "value": "bottom center", "label": "Botten" },
        { "value": "center left", "label": "Vänster" },
        { "value": "center right", "label": "Höger" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "label": "Minsta höjd",
      "default": 750
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Liten text ovanför rubriken"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Rubrik",
      "default": "Hållbara mattor till marknadens bästa priser"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Undertext",
      "default": "ReCarpet är specialister på demontering, kvalitetssäkring och leverans av textilplattor. För cirkulära lösningar i både ombyggnad och nyproduktion."
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Knapp 1 – text",
      "default": "Se våra produkter"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Knapp 1 – länk"
    }
  ],
  "presets": [
    {
      "name": "reCarpet Hero",
      "settings": {
        "heading": "Hållbara mattor till marknadens bästa priser",
        "subtext": "ReCarpet är specialister på demontering, kvalitetssäkring och leverans av textilplattor. För cirkulära lösningar i både ombyggnad och nyproduktion.",
        "btn1_label": "Se våra produkter",
        "min_height": 750
      }
    }
  ]
}
{% endschema %}
