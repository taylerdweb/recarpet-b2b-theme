{% comment %}
  reCarpet Hero Section
  Full-bleed hero with headline, subtitle and two CTAs
{% endcomment %}

<style>
  .rc-hero {
    position: relative;
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background-color: var(--rc-green, #1E4433);
  }
  .rc-hero__bg {
    position: absolute;
    inset: 0;
  }
  .rc-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
  }
  .rc-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.65) 0%,
      rgba(0,0,0,0.3) 50%,
      rgba(0,0,0,0.1) 100%
    );
  }
  .rc-hero__content {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 48px;
    width: 100%;
    color: #fff;
  }
  .rc-hero__eyebrow {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    margin-bottom: 16px;
  }
  .rc-hero__heading {
    font-family: var(--rc-font, 'DM Sans', sans-serif);
    font-size: clamp(40px, 5vw, 56px);
    font-weight: 500;
    line-height: 1.1;
    color: #fff;
    margin: 0 0 20px;
    max-width: 700px;
  }
  .rc-hero__subtext {
    font-family: var(--rc-font, 'DM Sans', sans-serif);
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255,255,255,0.88);
    max-width: 560px;
    margin: 0 0 36px;
  }
  .rc-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  @media (max-width: 768px) {
    .rc-hero__content { padding: 48px 20px; }
    .rc-hero { min-height: 500px; }
  }
</style>

<section class="rc-hero">
  <div class="rc-hero__bg">
    {%- if section.settings.background_image != blank -%}
      {{ section.settings.background_image | image_url: width: 1920 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- endif -%}
  </div>
  <div class="rc-hero__overlay"></div>
  <div class="rc-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="rc-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="rc-hero__heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.subtext != blank -%}
      <p class="rc-hero__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    <div class="rc-hero__actions">
      {%- if section.settings.btn1_label != blank -%}
        <a href="{{ section.settings.btn1_url }}" class="rc-btn rc-btn--primary">
          {{ section.settings.btn1_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "reCarpet Hero",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Bakgrundsbild"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bildposition",
      "options": [
        { "value": "center center", "label": "Mitten" },
        { "value": "top center", "label": "Topp" },
        { "value": "bottom center", "label": "Botten" },
        { "value": "center left", "label": "Vänster" },
        { "value": "center right", "label": "Höger" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "label": "Minsta höjd",
      "default": 750
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Liten text ovanför rubriken"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Rubrik",
      "default": "Hållbara mattor till marknadens bästa priser"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Undertext",
      "default": "ReCarpet är specialister på demontering, kvalitetssäkring och leverans av textilplattor. För cirkulära lösningar i både ombyggnad och nyproduktion."
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Knapp 1 – text",
      "default": "Se våra produkter"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Knapp 1 – länk"
    }
  ],
  "presets": [
    {
      "name": "reCarpet Hero",
      "settings": {
        "heading": "Hållbara mattor till marknadens bästa priser",
        "subtext": "ReCarpet är specialister på demontering, kvalitetssäkring och leverans av textilplattor. För cirkulära lösningar i både ombyggnad och nyproduktion.",
        "btn1_label": "Se våra produkter",
        "min_height": 750
      }
    }
  ]
}
{% endschema %}
