<!-- reCarpet header styling -->
<style>
  /* ── reCarpet Navbar ─────────────────────────────────── */
  .header-wrapper {
    background: var(--rc-off-white) !important;
    border-bottom: 1px solid var(--rc-off-black) !important;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header {
    max-width: var(--rc-max-width) !important;
    padding: 0 var(--rc-page-padding) !important;
    height: 72px;
    display: flex;
    align-items: center;
    gap: 0 !important;
  }

  /* Logo */
  .header__heading-link,
  .header__heading-link:hover {
    color: var(--rc-green) !important;
    text-decoration: none;
  }
  .header__heading { margin: 0; }
  .header__heading .h2 {
    font-family: var(--rc-font) !important;
    font-size: var(--rc-h5) !important;
    font-weight: 700 !important;
    color: var(--rc-green) !important;
    letter-spacing: -0.02em;
  }
  .header__heading-logo { max-width: 120px; height: auto; width: auto; }

  /* Nav links */
  .header__menu-item,
  .header__menu-item span,
  .header__menu-item .link {
    font-family: var(--rc-font) !important;
    font-size: var(--rc-text-sm) !important;
    font-weight: 500 !important;
    color: var(--rc-off-black) !important;
    text-decoration: none !important;
    line-height: 120% !important;
  }
  .header__menu-item:hover span,
  .header__menu-item:hover .link {
    color: var(--rc-green) !important;
  }
  .header__active-menu-item {
    text-decoration: underline !important;
  }

  /* Dropdown menus */
  .header__submenu {
    background: var(--rc-white) !important;
    border: 1px solid var(--rc-beige) !important;
    border-radius: var(--rc-radius-sm) !important;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
    padding: 8px 0 !important;
    min-width: 200px !important;
  }
  .header__submenu .header__menu-item {
    padding: 10px 20px !important;
    border-radius: 0 !important;
  }
  .header__submenu .header__menu-item:hover {
    background: var(--rc-cream, #F0EFEB) !important;
  }

  /* Header right side actions */
  .header__icons {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: auto;
  }

  /* B2B Login link */
  .rc-header-login {
    font-family: var(--rc-font);
    font-size: var(--rc-text-sm);
    font-weight: 500;
    color: var(--rc-off-black);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: var(--rc-radius-sm);
    transition: background 0.15s;
  }
  .rc-header-login:hover {
    background: var(--rc-cream);
    color: var(--rc-green);
  }

  /* Kontakta oss CTA button in nav */
  .rc-header-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    background: var(--rc-green);
    color: var(--rc-white) !important;
    border-radius: var(--rc-radius);
    font-family: var(--rc-font);
    font-size: var(--rc-text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .rc-header-cta:hover {
    background: var(--rc-green-hover);
    color: var(--rc-white) !important;
  }

  /* Hide cart icon for B2B (SparkLayer handles cart) */
  #cart-icon-bubble { display: none; }

  /* Mobile: reduce padding */
  @media (max-width: 989px) {
    .header { padding: 0 20px !important; height: 64px; }
  }

  /* ── Transparent header on homepage over hero ── */
  .header-wrapper--transparent {
    background: transparent !important;
    border-bottom: 1px solid transparent !important;
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .header-wrapper--transparent .header__heading .h2,
  .header-wrapper--transparent .header__heading-link {
    color: #fff !important;
  }
  .header-wrapper--transparent .header__menu-item span,
  .header-wrapper--transparent .header__menu-item .link,
  .header-wrapper--transparent .header__menu-item {
    color: #fff !important;
  }
  .header-wrapper--transparent .rc-header-login {
    color: #fff;
  }
  .header-wrapper--transparent .header__menu-item:hover span,
  .header-wrapper--transparent .header__menu-item:hover .link {
    color: rgba(255,255,255,0.7) !important;
  }
  .header-wrapper--transparent .rc-header-cta {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.85);
  }
  .header-wrapper--transparent .rc-header-cta:hover {
    background: rgba(255,255,255,0.15);
  }
  .header-wrapper--transparent .header__icon,
  .header-wrapper--transparent .header__icon svg {
    color: #fff !important;
    fill: #fff !important;
  }
  /* Scrolled state — solid white */
  .header-wrapper--scrolled {
    background: var(--rc-off-white) !important;
    border-bottom: 1px solid var(--rc-off-black) !important;
  }
  .header-wrapper--scrolled .header__heading .h2,
  .header-wrapper--scrolled .header__heading-link {
    color: var(--rc-green) !important;
  }
  .header-wrapper--scrolled .header__menu-item span,
  .header-wrapper--scrolled .header__menu-item .link,
  .header-wrapper--scrolled .header__menu-item {
    color: var(--rc-off-black) !important;
  }
  .header-wrapper--scrolled .rc-header-login {
    color: var(--rc-off-black);
  }
  .header-wrapper--scrolled .rc-header-cta {
    background: var(--rc-green);
    border: 1px solid transparent;
    color: var(--rc-white) !important;
  }
  .header-wrapper--scrolled .header__icon,
  .header-wrapper--scrolled .header__icon svg {
    color: var(--rc-off-black) !important;
    fill: var(--rc-off-black) !important;
  }

  /* Hover dropdown menus on desktop */
  @media (min-width: 990px) {
    header-menu details[open] > .header__submenu {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: opacity 0.2s ease-in-out, visibility 0.2s ease-in-out;
    }
    
    header-menu details:not([open]) > .header__submenu {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.2s ease-in-out, visibility 0.2s ease-in-out;
    }
  }
</style>

