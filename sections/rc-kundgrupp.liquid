{% comment %}
  reCarpet Kundgrupp — Customer group landing page section
  Used for: Fastighetsägare, Arkitekt, Hyresgäst, Entreprenör
{% endcomment %}

<style>
  /* Intro — full-bleed edge-to-edge split */
  .rc-kg-intro {
    background: var(--rc-cream);
    margin-top: -4.5rem;
    padding-top: 4.5rem;
  }
  .rc-kg-intro__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 37.5rem;
  }
  .rc-kg-intro__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* Keep text within the max-width zone on the left */
    padding: var(--rc-section-md) 4rem var(--rc-section-md) calc(max(3rem, (100vw - var(--rc-max-width)) / 2));
  }
  .rc-kg-intro__eyebrow {
    font-size: var(--rc-text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rc-text-muted);
    margin-bottom: 0.625rem;
  }
  .rc-kg-intro__heading {
    font-size: clamp(1.75rem, 3.5vw, var(--rc-h2));
    font-weight: 500;
    color: var(--rc-text);
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }
  .rc-kg-intro__body { font-size: var(--rc-text-base); line-height: var(--rc-body-lh); color: var(--rc-text-muted); margin: 0 0 0.75rem; }
  .rc-kg-intro__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .rc-kg-intro__image {
    position: relative;
    overflow: hidden;
  }
  .rc-kg-intro__image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Feature cards */
  .rc-kg-features {
    background: var(--rc-cream);
    padding: var(--rc-section-md) 0;
  }
  .rc-kg-features__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
  }
  .rc-kg-features__heading {
    font-family: var(--recarpet-dm-sans);
    font-size: clamp(1.75rem, 3.5vw, var(--rc-h3));
    font-weight: 500;
    line-height: 120%;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 3rem;
  }
  .rc-kg-features__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .rc-kg-feature {
    background: transparent;
  }
  .rc-kg-feature__image { aspect-ratio: 16/9; overflow: hidden; }
  .rc-kg-feature__image img { width: 100%; height: 100%; object-fit: cover; }
  .rc-kg-feature__placeholder { background: var(--rc-cream-alt); height: 12.5rem; }
  .rc-kg-feature__body { padding: 1.5rem; }
  .rc-kg-feature__title {
    font-family: var(--recarpet-dm-sans);
    font-size: var(--rc-h5);
    font-weight: 700;
    line-height: 140%;
    color: var(--base-color-brand--rc-off-black);
    margin: 0 0 0.625rem;
  }
  .rc-kg-feature__text { font-size: 1rem; line-height: 1.65; color: var(--base-color-brand--rc-off-black); margin: 0 0 1rem; }
  .rc-kg-feature__link {
    font-size: var(--rc-text-sm);
    font-weight: 600;
    color: var(--rc-green);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .rc-kg-feature__link::after { content: ' →'; }
  .rc-kg-feature__link:hover { text-decoration: underline; }

  /* Stats / highlight section */
  .rc-kg-stats {
    background: var(--rc-white);
    padding: var(--rc-section-md) 0;
  }
  .rc-kg-stats__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .rc-kg-stats__heading { font-size: clamp(1.375rem, 2.5vw, var(--rc-h4)); font-weight: 500; margin: 0 0 1rem; }
  .rc-kg-stats__body { font-size: var(--rc-text-base); line-height: 1.75; color: var(--rc-text-muted); margin: 0 0 0.75rem; }
  .rc-kg-stat-row {
    display: flex;
    gap: 2.5rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .rc-kg-stat { text-align: left; }
  .rc-kg-stat__number { font-size: var(--rc-h3); font-weight: 700; color: var(--rc-green); line-height: 1; }
  .rc-kg-stat__unit { font-size: var(--rc-text-base); color: var(--rc-text-muted); }
  .rc-kg-stat__label { font-size: var(--rc-text-xs); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--rc-text-muted); margin-top: 0.25rem; }
  .rc-kg-stats__image { border-radius: var(--rc-radius); overflow: hidden; aspect-ratio: 4/3; }
  .rc-kg-stats__image img { width: 100%; height: 100%; object-fit: cover; }

  @media (max-width: 900px) {
    .rc-kg-intro__inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .rc-kg-intro__text {
      padding: 3rem 1.25rem;
    }
    .rc-kg-intro__image {
      position: relative;
      min-height: 18.75rem;
    }
    .rc-kg-stats__inner,
    .rc-kg-features__grid { grid-template-columns: 1fr; gap: 2rem; }
    .rc-kg-features__inner,
    .rc-kg-stats__inner { padding: 0 1.25rem; }
  }
</style>

<!-- Intro — full-bleed split -->
<section class="rc-kg-intro">
  <div class="rc-kg-intro__inner">
    <div class="rc-kg-intro__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rc-kg-intro__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="rc-kg-intro__heading">{{ section.settings.intro_heading }}</h2>
      <p class="rc-kg-intro__body">{{ section.settings.intro_body }}</p>
      {%- if section.settings.intro_body_2 != blank -%}
        <p class="rc-kg-intro__body">{{ section.settings.intro_body_2 }}</p>
      {%- endif -%}
      <div class="rc-kg-intro__actions">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_url }}" class="rc-btn rc-btn--primary">{{ section.settings.btn1_label }}</a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_url }}" class="rc-btn rc-btn--outline">{{ section.settings.btn2_label }}</a>
        {%- endif -%}
      </div>
    </div>
    {%- if section.settings.intro_image != blank -%}
      <div class="rc-kg-intro__image">
        {{ section.settings.intro_image | image_url: width: 1200 | image_tag: loading: 'eager', sizes: '50vw' }}
      </div>
    {%- else -%}
      <div class="rc-kg-intro__image" style="background: var(--rc-cream-alt, #E6E3DE);"></div>
    {%- endif -%}
  </div>
</section>

<!-- Feature cards -->
{%- assign feature_blocks = section.blocks | where: 'type', 'feature' -%}
{%- if feature_blocks.size > 0 -%}
  <section class="rc-kg-features">
    <div class="rc-kg-features__inner">
      {%- if section.settings.features_heading != blank -%}
        <h2 class="rc-kg-features__heading">{{ section.settings.features_heading }}</h2>
      {%- endif -%}
      <div class="rc-kg-features__grid">
        {%- for block in feature_blocks -%}
          <div class="rc-kg-feature">
            <div class="rc-kg-feature__image">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.title }}" loading="lazy">
              {%- else -%}
                <div class="rc-kg-feature__placeholder"></div>
              {%- endif -%}
            </div>
            <div class="rc-kg-feature__body">
              <h3 class="rc-kg-feature__title">{{ block.settings.title }}</h3>
              <p class="rc-kg-feature__text">{{ block.settings.text }}</p>
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" class="rc-kg-feature__link">{{ block.settings.link_label | default: 'Läs mer' }}</a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

<!-- Stats / highlight -->
{%- assign stat_blocks = section.blocks | where: 'type', 'stat' -%}
{%- if section.settings.stats_heading != blank or stat_blocks.size > 0 -%}
  <section class="rc-kg-stats">
    <div class="rc-kg-stats__inner">
      <div>
        {%- if section.settings.stats_eyebrow != blank -%}
          <p class="rc-kg-intro__eyebrow">{{ section.settings.stats_eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.stats_heading != blank -%}
          <h2 class="rc-kg-stats__heading">{{ section.settings.stats_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.stats_body != blank -%}
          <p class="rc-kg-stats__body">{{ section.settings.stats_body }}</p>
        {%- endif -%}
        {%- if stat_blocks.size > 0 -%}
          <div class="rc-kg-stat-row">
            {%- for block in stat_blocks -%}
              <div class="rc-kg-stat">
                <div class="rc-kg-stat__number">{{ block.settings.number }}<span class="rc-kg-stat__unit">{{ block.settings.unit }}</span></div>
                <div class="rc-kg-stat__label">{{ block.settings.label }}</div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        {%- if section.settings.stats_btn_label != blank -%}
          <a href="{{ section.settings.stats_btn_url }}" class="rc-btn rc-btn--primary" style="margin-top:1.75rem;">{{ section.settings.stats_btn_label }}</a>
        {%- endif -%}
      </div>
      {%- if section.settings.stats_image != blank -%}
        <div class="rc-kg-stats__image">
          <img src="{{ section.settings.stats_image | image_url: width: 900 }}" alt="{{ section.settings.stats_heading }}" loading="lazy">
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "reCarpet Kundgrupp",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Intro"
    },
    { "type": "text", "id": "eyebrow", "label": "Liten text" },
    { "type": "textarea", "id": "intro_heading", "label": "Rubrik", "default": "Välkommen" },
    { "type": "textarea", "id": "intro_body", "label": "Text 1" },
    { "type": "textarea", "id": "intro_body_2", "label": "Text 2" },
    { "type": "image_picker", "id": "intro_image", "label": "Bild" },
    { "type": "text", "id": "btn1_label", "label": "Knapp 1 text" },
    { "type": "url", "id": "btn1_url", "label": "Knapp 1 länk" },
    { "type": "text", "id": "btn2_label", "label": "Knapp 2 text" },
    { "type": "url", "id": "btn2_url", "label": "Knapp 2 länk" },
    {
      "type": "header",
      "content": "Tjänstekort"
    },
    { "type": "text", "id": "features_heading", "label": "Rubrik för tjänstekort" },
    {
      "type": "header",
      "content": "Statistik / highlight"
    },
    { "type": "text", "id": "stats_eyebrow", "label": "Liten text" },
    { "type": "textarea", "id": "stats_heading", "label": "Rubrik" },
    { "type": "textarea", "id": "stats_body", "label": "Text" },
    { "type": "image_picker", "id": "stats_image", "label": "Bild" },
    { "type": "text", "id": "stats_btn_label", "label": "Knapptext" },
    { "type": "url", "id": "stats_btn_url", "label": "Knapp länk" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Tjänstekort",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "title", "label": "Titel" },
        { "type": "textarea", "id": "text", "label": "Text" },
        { "type": "url", "id": "link_url", "label": "Länk" },
        { "type": "text", "id": "link_label", "label": "Länktext", "default": "Läs mer" }
      ]
    },
    {
      "type": "stat",
      "name": "Statistik",
      "settings": [
        { "type": "text", "id": "number", "label": "Nummer" },
        { "type": "text", "id": "unit", "label": "Enhet (t.ex. m², t, %)" },
        { "type": "text", "id": "label", "label": "Etikett" }
      ]
    }
  ],
  "presets": [
    {
      "name": "reCarpet Kundgrupp"
    }
  ]
}
{% endschema %}
