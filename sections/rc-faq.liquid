<div class="rc-faq">
  <div class="rc-faq__container">
    {% if section.settings.heading %}
      <h2 class="rc-faq__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="rc-faq__list">
      {% for block in section.blocks %}
        {% if block.type == "faq" %}
          <details class="rc-faq__item">
            <summary class="rc-faq__summary">
              <span class="rc-faq__question">{{ block.settings.question }}</span>
              <span class="rc-faq__icon"></span>
            </summary>
            <div class="rc-faq__answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
  :root {
    --rc-cream-alt: #EFEFEF;
    --rc-green: #1E4433;
    --rc-text: #1a1a1a;
  }

  .rc-faq {
    width: 100%;
    padding: 80px 20px;
    background-color: white;
  }

  .rc-faq__container {
    max-width: 800px;
    margin: 0 auto;
  }

  .rc-faq__heading {
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 600;
    margin: 0 0 60px 0;
    text-align: center;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: var(--rc-text);
  }

  .rc-faq__list {
    display: flex;
    flex-direction: column;
  }

  .rc-faq__item {
    border-bottom: 1px solid var(--rc-cream-alt);
  }

  .rc-faq__item:last-child {
    border-bottom: none;
  }

  .rc-faq__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .rc-faq__summary::-webkit-details-marker {
    display: none;
  }

  .rc-faq__question {
    font-size: 16px;
    font-weight: 600;
    color: var(--rc-text);
    flex: 1;
    padding-right: 20px;
    text-align: left;
  }

  .rc-faq__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Plus icon created with CSS */
  .rc-faq__icon::before {
    content: '';
    width: 16px;
    height: 2px;
    background-color: var(--rc-green);
    position: absolute;
  }

  .rc-faq__icon::after {
    content: '';
    width: 2px;
    height: 16px;
    background-color: var(--rc-green);
    position: absolute;
  }

  /* Rotate minus on open */
  details[open] .rc-faq__icon::after {
    height: 0;
  }

  details[open] .rc-faq__icon::before {
    transform: rotate(0deg);
  }

  .rc-faq__answer {
    padding: 0 0 24px 0;
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--rc-text);
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    animation: slideDown 0.3s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .rc-faq {
      padding: 60px 20px;
    }

    .rc-faq__heading {
      margin-bottom: 40px;
    }

    .rc-faq__summary {
      padding: 20px 0;
    }

    .rc-faq__question {
      font-size: 15px;
      padding-right: 16px;
    }

    .rc-faq__answer {
      font-size: 14px;
      padding-bottom: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "RC FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "placeholder": "e.g., Frequently Asked Questions",
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "placeholder": "Enter the question",
          "default": ""
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "placeholder": "Enter the answer",
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RC FAQ"
    }
  ]
}
{% endschema %}
