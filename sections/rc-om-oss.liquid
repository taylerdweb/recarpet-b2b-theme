{% comment %}
  reCarpet Om oss — comprehensive page with 9 distinct sections
  A. Intro, B. Founder Quote, C. Team, D. Stats, E. Projects Portfolio,
  F. Expertise Quote, G. Services Summary, H. Vision, I. Sustainable Solution
{% endcomment %}

<style>
  /* ===== A. Intro Section ===== */
  .rc-about-intro {
    background: var(--rc-white);
    padding: var(--rc-section-md) 0;
  }
  .rc-about-intro__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .rc-about-intro__heading {
    font-size: clamp(1.75rem, 3vw, var(--rc-h3));
    font-weight: 500;
    color: var(--rc-text);
    margin: 0 0 1.25rem;
  }
  .rc-about-intro__body {
    font-size: var(--rc-text-base);
    line-height: 1.75;
    color: var(--rc-text-muted);
    margin: 0 0 1rem;
  }
  .rc-about-intro__image {
    border-radius: var(--rc-radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .rc-about-intro__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .rc-about-intro__quote {
    font-size: var(--rc-h5);
    font-weight: 500;
    line-height: 1.4;
    color: var(--rc-text);
    border-left: 0.25rem solid var(--rc-green);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
  }

  /* ===== B. Founder Quote Section ===== */
  .rc-about-quote-banner {
    background: var(--rc-green);
    padding: var(--rc-section-md) var(--rc-page-padding);
    text-align: center;
  }
  .rc-about-quote-banner__inner {
    max-width: 56.25rem;
    margin: 0 auto;
  }
  .rc-about-quote-banner__text {
    font-size: clamp(2rem, 4vw, var(--rc-h2));
    font-weight: 500;
    color: var(--rc-white);
    font-style: italic;
    line-height: 1.3;
    margin: 0 0 1.5rem;
  }
  .rc-about-quote-banner__attribution {
    font-size: var(--rc-text-base);
    color: var(--rc-white);
    opacity: 0.9;
  }
  .rc-about-quote-banner__author {
    font-weight: 500;
  }
  .rc-about-quote-banner__title {
    opacity: 0.8;
  }

  /* ===== C. Team Section ===== */
  .rc-about-team {
    background: var(--rc-white);
    padding: var(--rc-section-md) 0;
  }
  .rc-about-team__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
  }
  .rc-about-team__heading {
    font-size: clamp(1.75rem, 3vw, var(--rc-h3));
    font-weight: 500;
    color: var(--rc-text);
    margin: 0 0 3rem;
    text-align: center;
  }
  .rc-about-team__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .rc-team-card {
    display: flex;
    gap: 1.5rem;
  }
  .rc-team-card__photo {
    flex-shrink: 0;
    width: 8.75rem;
    height: 8.75rem;
    border-radius: 50%;
    overflow: hidden;
    background: var(--rc-cream);
  }
  .rc-team-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .rc-team-card__content {
    flex: 1;
  }
  .rc-team-card__name {
    font-size: var(--rc-text-md);
    font-weight: 600;
    color: var(--rc-text);
    margin: 0 0 0.25rem;
  }
  .rc-team-card__title {
    font-size: var(--rc-text-sm);
    font-weight: 500;
    color: var(--rc-green);
    margin: 0 0 0.75rem;
  }
  .rc-team-card__bio {
    font-size: var(--rc-text-sm);
    line-height: 1.6;
    color: var(--rc-text-muted);
    margin: 0 0 0.75rem;
  }
  .rc-team-card__contact {
    display: flex;
    gap: 1rem;
    font-size: var(--rc-text-sm);
  }
  .rc-team-card__contact a {
    color: var(--rc-green);
    text-decoration: none;
  }
  .rc-team-card__contact a:hover {
    text-decoration: underline;
  }

  /* ===== D. Stats Row ===== */
  .rc-about-stats {
    background: var(--rc-cream);
    padding: var(--rc-section-sm) 0;
  }
  .rc-about-stats__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .rc-stat__number {
    font-size: clamp(2.25rem, 4vw, var(--rc-h1));
    font-weight: 700;
    color: var(--rc-green);
    line-height: 1;
    margin-bottom: 0.375rem;
  }
  .rc-stat__label {
    font-size: var(--rc-text-sm);
    color: var(--rc-text-muted);
    line-height: 1.4;
  }

  /* ===== E. Projects Portfolio ===== */
  .rc-about-projects {
    background: var(--rc-white);
    padding: var(--rc-section-md) 0;
  }
  .rc-about-projects__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
  }
  .rc-about-projects__heading {
    font-size: clamp(1.75rem, 3vw, var(--rc-h3));
    font-weight: 500;
    color: var(--rc-text);
    margin: 0 0 3rem;
    text-align: center;
  }
  .rc-about-projects__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }
  .rc-project-category__title {
    font-size: var(--rc-text-md);
    font-weight: 600;
    color: var(--rc-text);
    margin: 0 0 1.25rem;
  }
  .rc-project-category__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .rc-project-category__item {
    font-size: var(--rc-text-sm);
    color: var(--rc-text-muted);
    line-height: 1.6;
  }

  /* ===== F. Expertise Quote ===== */
  .rc-about-expertise {
    background: var(--rc-white);
    padding: var(--rc-section-md) 0;
  }
  .rc-about-expertise__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .rc-about-expertise__body {
    font-size: var(--rc-text-base);
    line-height: 1.75;
    color: var(--rc-text-muted);
    margin: 0 0 1.5rem;
  }
  .rc-about-expertise__quote {
    font-size: var(--rc-h4);
    font-weight: 500;
    line-height: 1.4;
    color: var(--rc-text);
    font-style: italic;
    margin: 0;
  }

  /* ===== G. Services Summary ===== */
  .rc-about-services {
    background: var(--rc-cream);
    padding: var(--rc-section-md) 0;
  }
  .rc-about-services__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
  }
  .rc-about-services__heading {
    font-size: clamp(1.75rem, 3vw, var(--rc-h3));
    font-weight: 500;
    color: var(--rc-text);
    margin: 0 0 2rem;
  }
  .rc-about-services__list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .rc-about-services__item {
    font-size: var(--rc-text-base);
    color: var(--rc-text-muted);
    line-height: 1.6;
    padding-left: 1.5rem;
    position: relative;
  }
  .rc-about-services__item::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--rc-green);
    font-weight: 600;
  }
  .rc-about-services__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ===== H. Vision Section ===== */
  .rc-about-vision {
    background: var(--rc-white);
    padding: var(--rc-section-md) 0;
  }
  .rc-about-vision__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .rc-about-vision__heading {
    font-size: clamp(1.75rem, 3vw, var(--rc-h3));
    font-weight: 500;
    color: var(--rc-text);
    margin: 0 0 1.25rem;
  }
  .rc-about-vision__body {
    font-size: var(--rc-text-base);
    line-height: 1.75;
    color: var(--rc-text-muted);
    margin: 0;
  }
  .rc-about-vision__image {
    border-radius: var(--rc-radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .rc-about-vision__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== I. Sustainable Solution ===== */
  .rc-about-sustainability {
    background: var(--rc-white);
    padding: var(--rc-section-md) 0;
  }
  .rc-about-sustainability__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .rc-about-sustainability__image {
    border-radius: var(--rc-radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .rc-about-sustainability__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .rc-about-sustainability__heading {
    font-size: clamp(1.75rem, 3vw, var(--rc-h3));
    font-weight: 500;
    color: var(--rc-text);
    margin: 0 0 0.5rem;
  }
  .rc-about-sustainability__subtitle {
    font-size: var(--rc-text-base);
    font-weight: 500;
    color: var(--rc-green);
    margin: 0 0 1.5rem;
  }
  .rc-about-sustainability__body {
    font-size: var(--rc-text-base);
    line-height: 1.75;
    color: var(--rc-text-muted);
    margin: 0 0 1.5rem;
  }
  .rc-about-sustainability__body p {
    margin: 0 0 1rem;
  }
  .rc-about-sustainability__body p:last-child {
    margin: 0;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .rc-about-intro__inner,
    .rc-about-expertise__inner,
    .rc-about-vision__inner,
    .rc-about-sustainability__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .rc-about-team__grid {
      grid-template-columns: 1fr;
    }
    .rc-about-projects__grid {
      grid-template-columns: 1fr;
    }
    .rc-about-stats__inner {
      grid-template-columns: repeat(2, 1fr);
    }
    .rc-about-intro__inner,
    .rc-about-mission__inner,
    .rc-about-stats__inner,
    .rc-about-team__inner,
    .rc-about-projects__inner,
    .rc-about-expertise__inner,
    .rc-about-services__inner,
    .rc-about-vision__inner,
    .rc-about-sustainability__inner {
      padding: 0 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .rc-about-stats__inner {
      grid-template-columns: 1fr;
    }
    .rc-team-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .rc-team-card__photo {
      width: 7.5rem;
      height: 7.5rem;
    }
    .rc-team-card__contact {
      flex-direction: column;
      align-items: center;
    }
    .rc-about-services__buttons {
      flex-direction: column;
    }
  }
</style>

<!-- A. Intro Section -->
<section class="rc-about-intro">
  <div class="rc-about-intro__inner">
    <div>
      <h2 class="rc-about-intro__heading">{{ section.settings.intro_heading }}</h2>
      <p class="rc-about-intro__body">{{ section.settings.intro_body_1 }}</p>
      {%- if section.settings.intro_body_2 != blank -%}
        <p class="rc-about-intro__body">{{ section.settings.intro_body_2 }}</p>
      {%- endif -%}
    </div>
    <div>
      {%- if section.settings.intro_image != blank -%}
        <div class="rc-about-intro__image">
          <img src="{{ section.settings.intro_image | image_url: width: 900 }}" alt="Om ReCarpet" loading="lazy">
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- B. Founder Quote Banner -->
{%- if section.settings.quote != blank -%}
  <section class="rc-about-quote-banner">
    <div class="rc-about-quote-banner__inner">
      <p class="rc-about-quote-banner__text">{{ section.settings.quote }}</p>
      {%- if section.settings.quote_author != blank -%}
        <p class="rc-about-quote-banner__attribution">
          <span class="rc-about-quote-banner__author">{{ section.settings.quote_author }}</span>
          {%- if section.settings.quote_title != blank -%}
            <br><span class="rc-about-quote-banner__title">{{ section.settings.quote_title }}</span>
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

<!-- C. Team Section -->
{%- assign team_blocks = section.blocks | where: "type", "team_member" -%}
{%- if team_blocks.size > 0 -%}
  <section class="rc-about-team">
    <div class="rc-about-team__inner">
      {%- if section.settings.team_heading != blank -%}
        <h2 class="rc-about-team__heading">{{ section.settings.team_heading }}</h2>
      {%- endif -%}
      <div class="rc-about-team__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'team_member' -%}
            <div class="rc-team-card">
              {%- if block.settings.image != blank -%}
                <div class="rc-team-card__photo">
                  <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.name }}" loading="lazy">
                </div>
              {%- endif -%}
              <div class="rc-team-card__content">
                <h3 class="rc-team-card__name">{{ block.settings.name }}</h3>
                <p class="rc-team-card__title">{{ block.settings.title }}</p>
                <p class="rc-team-card__bio">{{ block.settings.bio }}</p>
                {%- if block.settings.email != blank or block.settings.phone != blank -%}
                  <div class="rc-team-card__contact">
                    {%- if block.settings.email != blank -%}
                      <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
                    {%- endif -%}
                    {%- if block.settings.phone != blank -%}
                      <a href="tel:{{ block.settings.phone }}">{{ block.settings.phone }}</a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

<!-- D. Stats Row -->
{%- assign stat_blocks = section.blocks | where: "type", "stat" -%}
{%- if stat_blocks.size > 0 -%}
  <section class="rc-about-stats">
    <div class="rc-about-stats__inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="rc-stat">
            <div class="rc-stat__number">{{ block.settings.number }}</div>
            <div class="rc-stat__label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

<!-- E. Projects Portfolio -->
{%- assign project_blocks = section.blocks | where: "type", "project_category" -%}
{%- if project_blocks.size > 0 -%}
  <section class="rc-about-projects">
    <div class="rc-about-projects__inner">
      {%- if section.settings.projects_heading != blank -%}
        <h2 class="rc-about-projects__heading">{{ section.settings.projects_heading }}</h2>
      {%- endif -%}
      <div class="rc-about-projects__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'project_category' -%}
            <div>
              <h3 class="rc-project-category__title">{{ block.settings.title }}</h3>
              {%- if block.settings.items != blank -%}
                <ul class="rc-project-category__list">
                  {%- assign items = block.settings.items | newline_to_br | split: '<br />' -%}
                  {%- for item in items -%}
                    {%- if item != blank -%}
                      <li class="rc-project-category__item">{{ item | strip }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

<!-- F. Expertise Quote Section -->
{%- if section.settings.expertise_body != blank or section.settings.expertise_quote != blank -%}
  <section class="rc-about-expertise">
    <div class="rc-about-expertise__inner">
      <div>
        {%- if section.settings.expertise_body != blank -%}
          <p class="rc-about-expertise__body">{{ section.settings.expertise_body }}</p>
        {%- endif -%}
      </div>
      <div>
        {%- if section.settings.expertise_quote != blank -%}
          <blockquote class="rc-about-expertise__quote">{{ section.settings.expertise_quote }}</blockquote>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

<!-- G. Services Summary Section -->
{%- if section.settings.services_heading != blank -%}
  <section class="rc-about-services">
    <div class="rc-about-services__inner">
      <h2 class="rc-about-services__heading">{{ section.settings.services_heading }}</h2>
      {%- if section.settings.services_list != blank -%}
        <ul class="rc-about-services__list">
          {%- assign services = section.settings.services_list | newline_to_br | split: '<br />' -%}
          {%- for service in services -%}
            {%- if service != blank -%}
              <li class="rc-about-services__item">{{ service | strip }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
      <div class="rc-about-services__buttons">
        {%- if section.settings.services_btn1_label != blank -%}
          <a href="{{ section.settings.services_btn1_url }}" class="rc-btn rc-btn--primary">{{ section.settings.services_btn1_label }}</a>
        {%- endif -%}
        {%- if section.settings.services_btn2_label != blank -%}
          <a href="{{ section.settings.services_btn2_url }}" class="rc-btn rc-btn--secondary">{{ section.settings.services_btn2_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

<!-- H. Vision Section -->
{%- if section.settings.vision_heading != blank or section.settings.vision_body != blank -%}
  <section class="rc-about-vision">
    <div class="rc-about-vision__inner">
      <div>
        <h2 class="rc-about-vision__heading">{{ section.settings.vision_heading }}</h2>
        <p class="rc-about-vision__body">{{ section.settings.vision_body }}</p>
      </div>
      {%- if section.settings.vision_image != blank -%}
        <div class="rc-about-vision__image">
          <img src="{{ section.settings.vision_image | image_url: width: 900 }}" alt="{{ section.settings.vision_heading }}" loading="lazy">
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

<!-- I. Sustainable Solution Section -->
{%- if section.settings.sustainability_heading != blank -%}
  <section class="rc-about-sustainability">
    <div class="rc-about-sustainability__inner">
      {%- if section.settings.sustainability_image != blank -%}
        <div class="rc-about-sustainability__image">
          <img src="{{ section.settings.sustainability_image | image_url: width: 900 }}" alt="{{ section.settings.sustainability_heading }}" loading="lazy">
        </div>
      {%- endif -%}
      <div>
        <h2 class="rc-about-sustainability__heading">{{ section.settings.sustainability_heading }}</h2>
        {%- if section.settings.sustainability_subtitle != blank -%}
          <p class="rc-about-sustainability__subtitle">{{ section.settings.sustainability_subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.sustainability_body != blank -%}
          <div class="rc-about-sustainability__body">
            {{ section.settings.sustainability_body | newline_to_br }}
          </div>
        {%- endif -%}
        {%- if section.settings.sustainability_btn_label != blank -%}
          <a href="{{ section.settings.sustainability_btn_url }}" class="rc-btn rc-btn--primary">{{ section.settings.sustainability_btn_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "reCarpet Om oss",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "A. Vår bakgrund (Intro)"
    },
    {
      "type": "text",
      "id": "intro_heading",
      "label": "Rubrik",
      "default": "Välkommen till ReCarpet"
    },
    {
      "type": "textarea",
      "id": "intro_body_1",
      "label": "Text (stycke 1)"
    },
    {
      "type": "textarea",
      "id": "intro_body_2",
      "label": "Text (stycke 2)"
    },
    {
      "type": "image_picker",
      "id": "intro_image",
      "label": "Bild"
    },
    {
      "type": "header",
      "content": "B. Founder Quote"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Citat"
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Författare"
    },
    {
      "type": "text",
      "id": "quote_title",
      "label": "Titel"
    },
    {
      "type": "header",
      "content": "C. Team"
    },
    {
      "type": "text",
      "id": "team_heading",
      "label": "Rubrik",
      "default": "Vårt team"
    },
    {
      "type": "header",
      "content": "E. Projects Portfolio"
    },
    {
      "type": "text",
      "id": "projects_heading",
      "label": "Rubrik",
      "default": "Några av våra lyckade projekt"
    },
    {
      "type": "header",
      "content": "F. Expertise Quote"
    },
    {
      "type": "textarea",
      "id": "expertise_body",
