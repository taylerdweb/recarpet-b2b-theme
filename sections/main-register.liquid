{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer register section-{{ section.id }}-padding">
  <h1>
    {{ 'customer.register.title' | t }}
  </h1>
  {%- form 'create_customer', novalidate: 'novalidate' -%}
    {%- if form.errors -%}
      <h2 class="form__message" tabindex="-1" autofocus>
        <span class="svg-wrapper">
          {{- 'icon-error.svg' | inline_asset_content -}}
        </span>
        {{ 'templates.contact.form.error_heading' | t }}
      </h2>
      <ul>
        {%- for field in form.errors -%}
          <li>
            {%- if field == 'form' -%}
              {{ form.errors.messages[field] }}
            {%- else -%}
              <a href="#RegisterForm-{{ field }}">
                {{ form.errors.translated_fields[field] | capitalize }}
                {{ form.errors.messages[field] }}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
    <div class="field">
      <input
        type="text"
        name="customer[first_name]"
        id="RegisterForm-FirstName"
        {% if form.first_name %}
          value="{{ form.first_name }}"
        {% endif %}
        autocomplete="given-name"
        placeholder="Förnamn"
        aria-required="true"
      >
      <label for="RegisterForm-FirstName">Förnamn</label>
    </div>
    <div class="field">
      <input
        type="text"
        name="customer[last_name]"
        id="RegisterForm-LastName"
        {% if form.last_name %}
          value="{{ form.last_name }}"
        {% endif %}
        autocomplete="family-name"
        placeholder="Efternamn"
        aria-required="true"
      >
      <label for="RegisterForm-LastName">Efternamn</label>
    </div>
    <div class="field">
      <input
        type="email"
        name="customer[email]"
        id="RegisterForm-email"
        {% if form.email %}
          value="{{ form.email }}"
        {% endif %}
        spellcheck="false"
        autocapitalize="off"
        autocomplete="email"
        aria-required="true"
        {% if form.errors contains 'email' %}
          aria-invalid="true"
          aria-describedby="RegisterForm-email-error"
        {% endif %}
        placeholder="E-postadress"
      >
      <label for="RegisterForm-email">E-postadress</label>
    </div>
    {%- if form.errors contains 'email' -%}
      <span id="RegisterForm-email-error" class="form__message">
        <span class="svg-wrapper">
          {{- 'icon-error.svg' | inline_asset_content -}}
        </span>
        {{ form.errors.translated_fields.email | capitalize }}
        {{ form.errors.messages.email }}.
      </span>
    {%- endif -%}
    <div class="field">
      <input
        type="tel"
        name="customer[phone]"
        id="RegisterForm-phone"
        autocomplete="tel"
        placeholder="Telefonnummer"
        aria-required="true"
      >
      <label for="RegisterForm-phone">Telefonnummer</label>
    </div>
    <div class="field">
      <input
        type="text"
        id="RegisterForm-company"
        autocomplete="organization"
        placeholder="Företagsnamn"
        aria-required="true"
      >
      <label for="RegisterForm-company">Företagsnamn</label>
    </div>
    <div class="field">
      <select id="RegisterForm-role" aria-required="true">
        <option value="" disabled selected>Välj roll</option>
        <option value="Arkitekt">Arkitekt</option>
        <option value="Byggare">Byggare</option>
        <option value="Golvläggare">Golvläggare</option>
        <option value="Fastighetsbolag">Fastighetsbolag</option>
        <option value="Entreprenör">Entreprenör</option>
        <option value="Hyresgäst">Hyresgäst</option>
      </select>
      <label for="RegisterForm-role">Roll / Verksamhet</label>
    </div>
    <!-- Packed into customer note — read by admin in Shopify -->
    <input type="hidden" name="customer[note]" id="RegisterForm-note" value="">
    <div class="field">
      <input
        type="password"
        name="customer[password]"
        id="RegisterForm-password"
        aria-required="true"
        {% if form.errors contains 'password' %}
          aria-invalid="true"
          aria-describedby="RegisterForm-password-error"
        {% endif %}
        placeholder="Lösenord"
      >
      <label for="RegisterForm-password">Lösenord</label>
    </div>
    {%- if form.errors contains 'password' -%}
      <span id="RegisterForm-password-error" class="form__message">
        <span class="svg-wrapper">
          {{- 'icon-error.svg' | inline_asset_content -}}
        </span>
        {{ form.errors.translated_fields.password | capitalize }}
        {{ form.errors.messages.password }}.
      </span>
    {%- endif -%}
    <button>
      Ansök om konto
    </button>
  {%- endform -%}
</div>

<script>
  (function() {
    var REDIRECT_PATH = '/account';

    var selector = '#create_customer, form[action$="/account"][method="post"]',
        $form = document.querySelectorAll(selector)[0];

    if ($form) {
      // Redirect after registration
      var $redirect = document.createElement('input');
      $redirect.setAttribute('name', 'return_to');
      $redirect.setAttribute('type', 'hidden');
      $redirect.value = REDIRECT_PATH;
      $form.appendChild($redirect);

      // On submit: pack company + role into hidden note field
      $form.addEventListener('submit', function() {
        var company = document.getElementById('RegisterForm-company');
        var role    = document.getElementById('RegisterForm-role');
        var note    = document.getElementById('RegisterForm-note');

        var parts = [];
        if (company && company.value.trim()) parts.push('Företag: ' + company.value.trim());
        if (role && role.value)              parts.push('Roll: ' + role.value);

        if (note && parts.length) {
          note.value = parts.join(' | ');
        }

        // Validate required custom fields
        var valid = true;
        if (company && !company.value.trim()) {
          company.focus();
          valid = false;
        }
        if (role && !role.value) {
          role.focus();
          valid = false;
        }
        if (!valid) return false;
      });
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.main-register.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
