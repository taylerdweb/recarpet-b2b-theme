{% comment %}
  reCarpet CTA Banner
  Split layout: large heading left, text + button right
  Used on homepage: "Ska du demontera eller föreskriva textilplattor?"
{% endcomment %}

<style>
  .rc-cta-banner {
    background: var(--rc-white);
    padding: var(--rc-section-md) 0;
  }
  .rc-cta-banner__inner {
    max-width: var(--rc-max-width);
    margin: 0 auto;
    padding: 0 var(--rc-page-padding);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .rc-cta-banner__heading {
    font-family: var(--rc-font);
    font-size: clamp(1.75rem, 3.5vw, var(--rc-h3));
    font-weight: 500;
    line-height: 1.15;
    color: var(--rc-text);
    margin: 0;
  }
  .rc-cta-banner__body {
    font-size: var(--rc-text-md);
    line-height: 1.6;
    color: var(--rc-text-muted);
    margin: 0 0 1.75rem;
  }
  @media (max-width: 768px) {
    .rc-cta-banner__inner {
      grid-template-columns: 1fr;
      padding: 0 1.25rem;
      gap: 1.5rem;
    }
    .rc-cta-banner { padding: var(--rc-section-sm) 0; }
  }
</style>

<section class="rc-cta-banner">
  <div class="rc-cta-banner__inner">
    <h2 class="rc-cta-banner__heading">{{ section.settings.heading }}</h2>
    <div>
      {%- if section.settings.body != blank -%}
        <p class="rc-cta-banner__body">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_url }}" class="rc-btn rc-btn--primary">
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "reCarpet CTA Banner",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Rubrik",
      "default": "Ska du demontera eller föreskriva textilplattor?"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Text",
      "default": "ReCarpet hanterar hela processen – från demontering till vidareförmedling – med högsta kvalitet. Boka demontering eller förskriv våra textilplattor. Tillsammans gör vi stor skillnad!"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Knapptext",
      "default": "Kontakta oss"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Knapp länk"
    }
  ],
  "presets": [
    {
      "name": "reCarpet CTA Banner"
    }
  ]
}
{% endschema %}
