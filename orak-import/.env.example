# Shopify credentials — behövs bara för --upload-images
# Kopiera den här filen till .env och fyll i dina uppgifter

# Din Shopify store URL (utan https://)
SHOPIFY_SHOP=recarpet.myshopify.com

# Admin API Access Token
# Shopify Admin → Settings → Apps → Develop apps → Create app
# Ge appen: write_products, write_files
SHOPIFY_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
