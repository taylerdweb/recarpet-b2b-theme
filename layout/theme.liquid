        // onReady fires after SparkLayer has fully rendered — the right time to patch the DOM
        onReady: async function (spark) {
          var SPARK_ELS = 'spark-pdp, spark-product-price, spark-product-card';

          // ── /m² injection via CSS ::after (no layout shift) ──
          // Inject a <style> into each spark element's shadow root so that
          // price <p> tags always show "/m²" via CSS — no DOM manipulation needed.
          var M2_STYLE_CSS = [
            // Price paragraphs inside .price-summary
            '.price-summary p::after { content: "/m\\00B2"; margin-left: 2px; }',
            // Rename "Qty" table header
            'th { font-size: 0; }',
            'th::after { font-size: 14px; }',
          ].join('\n');

          // Full CSS for shadow roots — targets short price <p> elements
          // SparkLayer uses Tailwind classes like text-h4, text-h5, font-medium etc for prices
          var M2_SHADOW_CSS = [
            // Price summary paragraphs
            '.price-summary p::after { content: " /m\\00B2"; }',
            // Single-variant price display (p tags with specific Tailwind price classes)
            'p.text-h4::after, p.text-h5::after { content: " /m\\00B2"; }',
            // Price break table header
            'th.text-left:first-child { font-size: 0; visibility: hidden; position: relative; }',
            'th.text-left:first-child::after { content: "m\\00B2"; font-size: 14px; visibility: visible; }',
          ].join('\n');

          function injectM2Style(el) {
            var root = el.shadowRoot;
            if (!root || root.querySelector('[data-rc-m2-style]')) return;
            var style = document.createElement('style');
            style.setAttribute('data-rc-m2-style', '1');
            style.textContent = M2_SHADOW_CSS;
            root.appendChild(style);
          }

          // Also patch the "Qty" header via DOM for shadow roots that don't use th.text-left
          function patchQtyHeaders(root) {
            root.querySelectorAll('th').forEach(function (th) {
              if (th.textContent.trim() === 'Qty' && !th.dataset.rcPatched) {
                th.textContent = 'm\u00B2';
                th.dataset.rcPatched = '1';
              }
            });
          }

          // Fallback: DOM-based /m² append for elements where CSS ::after doesn't work
          function appendM2(p) {
            if (p.dataset.m2) return;
            // Skip if already has /m² (from CSS or previous patch)
            if (p.textContent.indexOf('/m\u00B2') !== -1) return;
            var text = p.textContent.trim();
            if (!text) return;
            p.dataset.m2 = '1';
            var span = document.createElement('span');
            span.style.cssText = 'margin-left:2px';
            span.textContent = '/m\u00B2';
            p.appendChild(span);
          }

          function patchRoot(root, insideSpark) {
            patchQtyHeaders(root);
            root.querySelectorAll('.price-summary p').forEach(appendM2);
            if (insideSpark) {
              root.querySelectorAll('p').forEach(function (p) {
                var t = p.textContent.trim();
                if (t.length > 0 && t.length < 80 && /\d/.test(t)) appendM2(p);
              });
            }
          }

          function patchElement(el) {
            // Prefer CSS injection (instant, no flash)
            injectM2Style(el);
            // Fallback DOM patching for edge cases
            patchRoot(el, true);
            if (el.shadowRoot) {
              patchQtyHeaders(el.shadowRoot);
            }
          }

          function watchElement(el) {
            if (el.dataset.m2watched) return;
            el.dataset.m2watched = '1';
            patchElement(el);
            if (el.shadowRoot) {
              var obs = new MutationObserver(function () {
                injectM2Style(el); // Re-inject if shadow root was replaced
                patchQtyHeaders(el.shadowRoot);
              });
              obs.observe(el.shadowRoot, { childList: true, subtree: true });
              setTimeout(function () { obs.disconnect(); }, 10000);
            }
          }

          // Set default quantity to 5 on all product cards
          function setDefaultQty(el) {
            var inputs = (el.shadowRoot || el).querySelectorAll('input[type="number"]');
            inputs.forEach(function(input) {
              if (input.value === '1' || input.value === '') {
                var nativeInputValueSetter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
                nativeInputValueSetter.call(input, '5');
                input.dispatchEvent(new Event('input', { bubbles: true }));
                input.dispatchEvent(new Event('change', { bubbles: true }));
              }
            });
          }

          document.querySelectorAll('spark-product-card').forEach(function(card) {
            setDefaultQty(card);
            var obs = new MutationObserver(function() { setDefaultQty(card); });
            obs.observe(card.shadowRoot || card, { childList: true, subtree: true });
            setTimeout(function() { obs.disconnect(); }, 5000);
          });

          // Patch light DOM (by class only — safe for whole document)
          patchRoot(document, false);

          // Watch all existing SparkLayer elements
          document.querySelectorAll(SPARK_ELS).forEach(watchElement);

          // Poll for shadow roots — they may appear after onReady fires
          var pollCount = 0;
          var poll = setInterval(function () {
            document.querySelectorAll(SPARK_ELS).forEach(function (el) {
              injectM2Style(el);
              if (el.shadowRoot) patchQtyHeaders(el.shadowRoot);
            });
            if (++pollCount >= 20) clearInterval(poll); // stop after 10s
          }, 500);

          // Watch body for SparkLayer elements added after initial load
          var bodyObs = new MutationObserver(function (mutations) {
            mutations.forEach(function (mut) {
              mut.addedNodes.forEach(function (node) {
                if (node.nodeType !== 1) return;
                if (node.matches && node.matches(SPARK_ELS)) watchElement(node);
                if (node.querySelectorAll) node.querySelectorAll(SPARK_ELS).forEach(watchElement);
              });
            });
          });
          bodyObs.observe(document.body, { childList: true, subtree: true });

          // ── Fakturauppgifter: replace customer-reference / notes input with 3 labelled inputs ──
          // SparkLayer may render the field as <input> or <textarea>, with id "customer-reference"
          // or with our placeholder text, inside a shadow root OR in the regular DOM.

          function injectFakturaFields(root) {
            // Broad selector: input OR textarea, by id OR placeholder content
            var selectors = [
              'input#customer-reference',
              'textarea#customer-reference',
              'input[placeholder*="Org.nr"]',
              'textarea[placeholder*="Org.nr"]',
              'input[id*="reference"]',
              'textarea[id*="reference"]',
              'input[id*="note"]',
              'textarea[id*="note"]'
            ];
            var input = null;
            for (var s = 0; s < selectors.length; s++) {
              input = root.querySelector(selectors[s]);
              if (input && !input.dataset.fakSplitted) break;
              input = null;
            }
            if (!input || input.dataset.fakSplitted) return;
            input.dataset.fakSplitted = '1';
            input.style.display = 'none';

            // Also hide the parent label/wrapper if it contains our placeholder
            var parent = input.parentElement;
            if (parent && parent.querySelector('label')) {
              // keep the parent visible, just hide the original input
            }

            var FIELDS = [
              { key: 'orgnr',  label: 'Org.nr',          type: 'text',  ph: 'ex. 556123-4567' },
              { key: 'fepost', label: 'Faktura-e-post',  type: 'email', ph: 'ex. faktura@foretag.se' },
              { key: 'ref',    label: 'Referensnummer',  type: 'text',  ph: 'ex. PO-2026-001' }
            ];

            var wrap = document.createElement('div');
            wrap.setAttribute('data-fak-wrap', '1');
            wrap.style.cssText = 'display:flex;flex-direction:column;gap:10px;margin-bottom:8px;';

            function sync() {
              var vals = FIELDS.map(function(f) {
                var el = wrap.querySelector('[data-fk="' + f.key + '"]');
                return f.label + ': ' + (el ? el.value.trim() : '');
              });
              var combined = vals.join(' | ');
              // Handle both input and textarea
              var nativeSetter = Object.getOwnPropertyDescriptor(
                input.tagName === 'TEXTAREA' ? window.HTMLTextAreaElement.prototype : window.HTMLInputElement.prototype,
                'value'
              ).set;
              nativeSetter.call(input, combined);
              ['input', 'change'].forEach(function(ev) {
                input.dispatchEvent(new Event(ev, { bubbles: true, composed: true }));
              });
            }

            FIELDS.forEach(function(f) {
              var row = document.createElement('div');
              row.style.cssText = 'display:flex;flex-direction:column;gap:4px;';

              var lbl = document.createElement('label');
              lbl.textContent = f.label;
              lbl.style.cssText = 'font-size:13px;font-weight:600;color:inherit;display:block;margin-bottom:2px;';

              var inp = document.createElement('input');
              inp.type        = f.type;
              inp.placeholder = f.ph;
              inp.dataset.fk  = f.key;
              inp.className   = input.className;
              inp.style.cssText = 'padding:8px 10px;border:1px solid #ccc;border-radius:6px;font-size:14px;width:100%;box-sizing:border-box;transition:border-color 0.2s;';
              if (f.type === 'email') {
                inp.setAttribute('pattern', '[^@\\s]+@[^@\\s]+\\.[^@\\s]+');
                inp.setAttribute('autocomplete', 'email');
                inp.setAttribute('inputmode', 'email');
              }
              if (f.key === 'orgnr') {
                inp.setAttribute('pattern', '\\d{6}-?\\d{4}');
                inp.setAttribute('inputmode', 'numeric');
              }

              var errMsg = document.createElement('span');
              errMsg.style.cssText = 'font-size:11px;color:#d32f2f;display:none;margin-top:2px;';
              errMsg.dataset.fkErr = f.key;

              inp.addEventListener('input', sync);
              inp.addEventListener('input', function() {
                var v = inp.value.trim();
                var valid = true;
                var msg = '';
                if (f.type === 'email' && v.length > 0) {
                  valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
                  msg = valid ? '' : 'Ange en giltig e-postadress';
                }
                if (f.key === 'orgnr' && v.length > 0) {
                  valid = /^\d{6}-?\d{4}$/.test(v);
                  msg = valid ? '' : 'Ange org.nr som 556123-4567';
                }
                inp.style.borderColor = v.length === 0 ? '#ccc' : (valid ? '#4caf50' : '#d32f2f');
                errMsg.style.display = msg ? 'block' : 'none';
                errMsg.textContent = msg;
              });

              row.appendChild(lbl);
              row.appendChild(inp);
              row.appendChild(errMsg);
              wrap.appendChild(row);
            });

            input.parentNode.insertBefore(wrap, input);
            console.log('[reCarpet] Fakturauppgifter: injected 3 fields, replaced', input.tagName, input.id || input.placeholder);
          }

          // Scan regular DOM + all shadow roots (drawer, checkout, cart, etc.)
          function runFakturaInjection() {
            // 1. Regular DOM (in case SparkLayer renders outside shadow root)
            injectFakturaFields(document);

            // 2. Known SparkLayer components
            var sparkEls = document.querySelectorAll('spark-drawer, spark-cart, spark-checkout, spark-pdp, [class*="spark"]');
            sparkEls.forEach(function(el) {
              if (el.shadowRoot) injectFakturaFields(el.shadowRoot);
            });

            // 3. Broader fallback: any element with a shadow root
            document.querySelectorAll('*').forEach(function(el) {
              if (el.shadowRoot) injectFakturaFields(el.shadowRoot);
            });
          }

          var fakPoll = setInterval(runFakturaInjection, 500);
          setTimeout(function() { clearInterval(fakPoll); }, 120000);

          // ── Montering-tillval: auto-add vid köp ────────────────────────────────
          var MONTERING_PRICE_PER_M2 = 45;

          var addonEl = document.getElementById('montering-addon');
          var checkboxEl = document.getElementById('montering-checkbox');
          var subtotalEl = document.getElementById('montering-subtotal');

          if (addonEl && checkboxEl) {
            // Visa checkbox (döljs i HTML tills JS laddats)
            addonEl.style.display = '';

            // Hämta kvantitet från spark-pdp:s input (shadow DOM)
            function getSparkQuantity() {
              var pdp = document.querySelector('spark-pdp');
              if (!pdp) return 1;
              var root = pdp.shadowRoot || pdp;
              var input = root.querySelector('input[type="number"]');
              if (input) return parseInt(input.value, 10) || 1;
              var inputs = root.querySelectorAll('input');
              for (var i = 0; i < inputs.length; i++) {
                var v = parseInt(inputs[i].value, 10);
                if (v > 0) return v;
              }
              return 1;
            }

            // Uppdatera delsumma
            function updateMonteringSubtotal() {
              if (!checkboxEl.checked) { subtotalEl.style.display = 'none'; return; }
              var qty = getSparkQuantity();
              if (qty > 0) {
                subtotalEl.textContent = 'Montering: ' + qty + ' m\u00B2 \u00D7 ' + MONTERING_PRICE_PER_M2 + ' kr = ' + (qty * MONTERING_PRICE_PER_M2) + ' kr';
                subtotalEl.style.display = '';
              }
            }
            checkboxEl.addEventListener('change', updateMonteringSubtotal);
            setInterval(updateMonteringSubtotal, 1000);

            // ── Montering bundling via customAttributes ─────────────────────────
            //
            // When a customer adds a product WITH the montering checkbox checked,
            // we pass customAttributes: [{ key: "montering", value: "true" }].
            // SparkLayer creates a SEPARATE line item from the same SKU added
            // without the attribute. This means the cart can show:
            //   - Product A (6 m²)                    ← no montering
            //   - Product A (4 m²) — Inkl. montering  ← with montering
            //
            // The montering service line item syncs to the total quantity of
            // all cart items that have the montering customAttribute.
            //
            var MONTERING_SKU = 'RC-SERVICE-MONTERING';
            var MONTERING_ATTR = { key: 'montering', value: 'true' };
            var _origSparkUpdateCart = window.spark._updateCart.bind(window.spark);
            var _monteringBusy = false;
            var _monteringUserRemoved = false;

            // ── Helper: check if a cart item has the montering attribute ──
            function hasMonteringAttr(item) {
              return item.customAttributes && item.customAttributes.some(function(a) {
                return a.key === 'montering' && a.value === 'true';
              });
            }

            // ── Silent cart update ──
            function silentUpdateCart(payload) {
              _monteringBusy = true;
              return _origSparkUpdateCart(payload).then(function(r) {
                _monteringBusy = false;
                return r;
              }).catch(function(err) {
                _monteringBusy = false;
              });
            }

            // ── Sync montering qty with items that have montering attribute ──
            // Only counts quantities of cart items with customAttributes montering=true.
            // Never creates montering — only PDP add with checkbox does that.
            function syncMonteringWithCart() {
              if (_monteringBusy || _monteringUserRemoved) return;

              window.spark.getCart().then(function(cart) {
                if (!cart || !cart.items) return;

                var monteringQty = 0;
                var attrQty = 0;

                cart.items.forEach(function(item) {
                  if (item.sku === MONTERING_SKU) {
                    monteringQty = item.quantity;
                  } else if (item.sku && item.sku.indexOf('RC-SERVICE') === -1 && hasMonteringAttr(item)) {
                    attrQty += item.quantity;
                  }
                });

                // If montering not in cart, do nothing
                if (monteringQty === 0) return;

                // If no attributed items left, remove montering
                if (attrQty === 0) {
                  console.log('[reCarpet] Inga monterings-produkter kvar — tar bort montering');
                  silentUpdateCart({ products: [{ sku: MONTERING_SKU, quantity: 0 }] });
                  return;
                }

                // Sync montering to match attributed total
                if (monteringQty !== attrQty) {
                  console.log('[reCarpet] Synkar montering: ' + monteringQty + ' → ' + attrQty + ' m²');
                  silentUpdateCart({ products: [{ sku: MONTERING_SKU, quantity: attrQty }] });
                }
              }).catch(function() {});
            }

            // ── Wrap _updateCart to trigger sync after every cart change ──
            // IMPORTANT: always return result unmodified so SparkLayer works normally.
            window.spark._updateCart = function(payload, t, n) {
              try {
                // Detect manual montering removal first
                if (payload && payload.products && !_monteringBusy) {
                  var isMonteringRemoval = payload.products.some(function(p) {
                    return p.sku === MONTERING_SKU && (p.quantity === 0 || (p.adjustQuantity && p.adjustQuantity < 0));
                  });
                  if (isMonteringRemoval) {
                    _monteringUserRemoved = true;
                    return _origSparkUpdateCart(payload, t, n);
                  }
                }

                // Skip everything for our own silent calls
                if (_monteringBusy) return _origSparkUpdateCart(payload, t, n);

                // Ignore calls that only touch montering
                var isOwnCall = payload && payload.products &&
                  payload.products.length === 1 && payload.products[0].sku === MONTERING_SKU;
                if (isOwnCall) return _origSparkUpdateCart(payload, t, n);

                // Detect PDP add (adjustQuantity > 0 for non-service SKUs)
                var isPDPAdd = payload && payload.products && payload.products.some(function(p) {
                  return p.adjustQuantity && p.adjustQuantity > 0 && p.sku && p.sku.indexOf('RC-SERVICE') === -1;
                });

                // If checkbox checked, inject customAttributes onto the carpet products
                // This creates a SEPARATE line item from the same SKU added without attributes
                var addedQty = 0;
                if (isPDPAdd && checkboxEl && checkboxEl.checked) {
                  payload = JSON.parse(JSON.stringify(payload)); // deep clone
                  payload.products.forEach(function(p) {
                    if (p.adjustQuantity && p.adjustQuantity > 0 && p.sku && p.sku.indexOf('RC-SERVICE') === -1) {
                      p.customAttributes = [MONTERING_ATTR];
                      addedQty += p.adjustQuantity;
                    }
                  });
                }

                // Call original (with potentially modified payload)
                var result = _origSparkUpdateCart(payload, t, n);

                if (result && typeof result.then === 'function') {
                  result.then(function() {
                    // If PDP add with checkbox, also add montering service
                    if (isPDPAdd && checkboxEl && checkboxEl.checked && addedQty > 0) {
                      _monteringUserRemoved = false;
                      silentUpdateCart({ products: [{ sku: MONTERING_SKU, adjustQuantity: addedQty }] });
                    } else {
                      // For all other cart changes, sync montering after a short delay
                      setTimeout(syncMonteringWithCart, 800);
                    }
                  });
                }

                return result;
              } catch (e) {
                console.warn('[reCarpet] updateCart wrapper error:', e);
                return _origSparkUpdateCart(payload, t, n);
              }
            };

            // ── Hide montering qty controls & delete button in cart ──
            // Shadow roots are forced open via attachShadow override above.

            // Cache which SKU+qty combos have montering attr (from cart API)
            var _monteringItemKeys = {}; // { sku+qty: true } for items with montering attr

            function refreshMonteringItemKeys(cb) {
              window.spark.getCart().then(function(cart) {
                if (!cart || !cart.items) return;
                _monteringItemKeys = {};
                cart.items.forEach(function(item) {
                  if (item.sku && item.sku !== MONTERING_SKU && hasMonteringAttr(item)) {
                    _monteringItemKeys[item.sku] = true;
                  }
                });
                if (cb) cb();
              }).catch(function() {});
            }

            function lockMonteringRows() {
              // Process both drawer (slide-out) and cart (full page) shadow roots
              var targets = ['spark-drawer', 'spark-cart'];
              targets.forEach(function(tag) {
                var el = document.querySelector(tag);
                if (!el || !el.shadowRoot) return;
                lockMonteringRowsIn(el.shadowRoot);
              });
            }

            var _lockRunning = false; // prevent re-entry from MutationObserver loop

            function lockMonteringRowsIn(sr) {
              if (_lockRunning) return;
              _lockRunning = true;

              try {
                sr.querySelectorAll('.py-4').forEach(function(row) {
                  // Hide "per styck" and clean up "montering: true" → "Montering"
                  row.querySelectorAll('p, span, small, div').forEach(function(el) {
                    if (el.children.length === 0 && el.textContent.trim() === 'per styck') {
                      el.style.cssText = 'display:none !important;';
                    }
                  });
                  // Fix "montering: true" → "Montering"
                  row.querySelectorAll('span').forEach(function(span) {
                    if (span.textContent.trim() === 'montering: true') {
                      span.textContent = 'Montering';
                    }
                  });

                  // Find SKU in this row
                  var skuText = '';
                  row.querySelectorAll('p, span, small').forEach(function(el) {
                    var t = el.textContent.trim();
                    if (t.indexOf('RC-SERVICE-MONTERING') !== -1) skuText = 'RC-SERVICE-MONTERING';
                    else if (t.indexOf('SKU:') !== -1) skuText = t.replace('SKU:', '').trim();
                    else if (!skuText && t.indexOf('RC-') === 0 && t.length < 40) skuText = t;
                  });

                  // Check if THIS specific row has the "Montering" attribute rendered by SparkLayer
                  var rowHasMonteringAttr = false;
                  row.querySelectorAll('span').forEach(function(span) {
                    var t = span.textContent.trim();
                    if (t === 'Montering' || t === 'montering: true' || t === 'montering') {
                      var parent = span.parentElement;
                      if (parent && parent.querySelector('svg')) {
                        rowHasMonteringAttr = true;
                      }
                    }
                  });

                  // ── Montering service row: lock controls ──
                  if (skuText === 'RC-SERVICE-MONTERING') {
                    if (row.dataset.rcLocked) return; // prevent duplicate elements
                    row.dataset.rcLocked = '1';

                    // Hide ALL buttons (qty +/-, delete)
                    row.querySelectorAll('button').forEach(function(btn) {
                      btn.style.cssText = 'display:none !important;';
                    });

                    // Hide qty input wrapper
                    var qtyWrapper = row.querySelector('.mt-2');
                    if (qtyWrapper) {
                      qtyWrapper.style.cssText = 'display:none !important;';
                    }

                    // Show qty as static text
                    var inp = row.querySelector('input');
                    var qty = inp ? inp.value : '';
                    if (qty) {
                      var qtyText = document.createElement('div');
                      qtyText.className = 'rc-montering-qty';
                      qtyText.textContent = qty + ' m\u00B2';
                      qtyText.style.cssText = 'font-size:13px;color:#666;margin-top:8px;';
                      var header = row.querySelector('header');
                      if (header && header.parentNode) {
                        header.parentNode.insertBefore(qtyText, header.nextSibling);
                      }
                    }

                    if (!row.querySelector('.rc-montering-note')) {
                      var header2 = row.querySelector('header');
                      if (header2) {
                        var note = document.createElement('div');
                        note.className = 'rc-montering-note';
                        note.textContent = 'Synkas automatiskt med monterings-produkter';
                        note.style.cssText = 'font-size:11px;color:#999;font-style:italic;margin-top:4px;';
                        header2.parentNode.insertBefore(note, header2.nextSibling);
                      }
                    }
                    return;
                  }

                  // ── Carpet rows: show "Inkl. montering" only if THIS row has the attribute ──
                  if (rowHasMonteringAttr) {
                    if (!row.querySelector('.rc-montering-label')) {
                      var header = row.querySelector('header');
                      if (header) {
                        var label = document.createElement('div');
                        label.className = 'rc-montering-label';
                        label.textContent = 'Inkl. montering +45 kr/m\u00B2';
                        label.style.cssText = 'font-size:11px;color:#28AB76;font-weight:500;margin-top:2px;';
                        header.parentNode.insertBefore(label, header.nextSibling);
                      }
                    }
                  }
                });
              } finally {
                _lockRunning = false;
              }
            }

            // Use MutationObserver for instant response (no flickering)
            // Watches both spark-drawer (slide-out) and spark-cart (full page).
            var _sparkObservers = {}; // keyed by tag name
            function watchSparkCart(tag) {
              var el = document.querySelector(tag);
              if (!el || !el.shadowRoot) return;
              if (_sparkObservers[tag]) return; // already watching

              refreshMonteringItemKeys(); // fetch attr data from cart API
              lockMonteringRows(); // initial run

              var _mutDebounce = null;
              _sparkObservers[tag] = new MutationObserver(function() {
                clearTimeout(_mutDebounce);
                _mutDebounce = setTimeout(function() {
                  refreshMonteringItemKeys();
                  setTimeout(lockMonteringRows, 200);
                }, 150);
                lockMonteringRows();
              });
              _sparkObservers[tag].observe(el.shadowRoot, {
                childList: true, subtree: true
              });
            }

            // Watch for spark-drawer and spark-cart appearing in the DOM
            var _docObserver = new MutationObserver(function() {
              watchSparkCart('spark-drawer');
              watchSparkCart('spark-cart');
            });
            _docObserver.observe(document.body, { childList: true, subtree: true });

            // Also poll as fallback
            setInterval(function() {
              watchSparkCart('spark-drawer');
              watchSparkCart('spark-cart');
            }, 1000);
          }

          // ── B2B Cart icon: count badge + animation ────────────────────────────
          (function() {
            var cartIcon = document.getElementById('rc-cart-icon');
            var cartCount = document.getElementById('rc-cart-count');
            if (!cartIcon || !cartCount) return;

            var _lastCount = -1; // track previous count for animation trigger

            function updateCartBadge(animate) {
              window.spark.getCart().then(function(cart) {
                if (!cart || !cart.items) return;
                // Count number of line items (not total quantity)
                var total = cart.items.length;

                // Update badge
                if (total > 0) {
                  cartCount.textContent = total > 99 ? '99+' : total;
                  cartCount.style.display = '';
                } else {
                  cartCount.style.display = 'none';
                }

                // Animate if count increased
                if (animate && total > _lastCount && _lastCount >= 0) {
                  cartIcon.classList.remove('rc-cart-icon--animate');
                  cartCount.classList.remove('rc-cart-count--animate');
                  void cartIcon.offsetWidth; // force reflow
                  cartIcon.classList.add('rc-cart-icon--animate');
                  cartCount.classList.add('rc-cart-count--animate');
                  setTimeout(function() {
                    cartIcon.classList.remove('rc-cart-icon--animate');
                    cartCount.classList.remove('rc-cart-count--animate');
                  }, 500);
                }

                _lastCount = total;
              }).catch(function() {});
            }

            // Initial load
            updateCartBadge(false);

            // Poll for updates (catches all cart changes)
            setInterval(function() { updateCartBadge(true); }, 1500);

            // Open SparkLayer cart drawer on click
            cartIcon.addEventListener('click', function(e) {
              e.preventDefault();
              if (window.spark && typeof window.spark.openDrawer === 'function') {
                window.spark.openDrawer();
              }
            });
          })();
          // ──────────────────────────────────────────────────────────────────────────
        },
      };
      </script>
      <!-- Force SparkLayer shadow roots to open mode so we can style cart items -->
      <script>
      (function() {
        var origAttachShadow = Element.prototype.attachShadow;
        Element.prototype.attachShadow = function(init) {
          // Only force open for SparkLayer components (spark-*)
          if (init && init.mode === 'closed' && this.tagName && this.tagName.toLowerCase().indexOf('spark') === 0) {
            init = Object.assign({}, init, { mode: 'open' });
          }
          return origAttachShadow.call(this, init);
        };
      })();
      </script>
