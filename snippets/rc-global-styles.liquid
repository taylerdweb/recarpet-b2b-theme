{% comment %}
  reCarpet Global Styles
  Design tokens and shared styles — single source of truth for all rc-* sections.
  Values extracted from recarpet.se Webflow export.
{% endcomment %}

<style>
  :root {
    /* ===== Font ===== */
    --rc-font: 'DM Sans', sans-serif;
    --recarpet-dm-sans: 'DM Sans', sans-serif;

    /* ===== Base Colors — Brand ===== */
    --base-color-brand--rc-re-green: #1e4433;
    --base-color-brand--rc-sage-green: #6c9985;
    --base-color-brand--rc-yellow: #edb81e;
    --base-color-brand--rc-beige: #e6e3de;
    --base-color-brand--rc-white: #f6f6f6;
    --base-color-brand--rc-off-black: #121212;
    --base-color-brand--white: white;
    --base-color-brand--black: black;

    /* ===== Base Colors — Neutral ===== */
    --base-color-neutral--white: white;
    --base-color-neutral--black: black;
    --base-color-neutral--neutral-lightest: #eee;
    --base-color-neutral--neutral-lighter: #ccc;
    --base-color-neutral--neutral-light: #aaa;
    --base-color-neutral--neutral: #666;
    --base-color-neutral--neutral-dark: #444;
    --base-color-neutral--neutral-darker: #222;
    --base-color-neutral--neutral-darkest: #111;

    /* ===== Base Colors — System ===== */
    --base-color-system--success-green: #027a48;
    --base-color-system--success-green-light: #ecfdf3;
    --base-color-system--error-red: #b42318;
    --base-color-system--error-red-light: #fef3f2;

    /* ===== Semantic — Background ===== */
    --background-color--background-primary: var(--base-color-neutral--white);
    --background-color--background-secondary: var(--base-color-neutral--neutral-lightest);
    --background-color--background-tertiary: var(--base-color-neutral--neutral-light);
    --background-color--background-alternate: var(--base-color-neutral--black);
    --background-color--background-success: var(--base-color-system--success-green-light);
    --background-color--background-error: var(--base-color-system--error-red-light);

    /* ===== Semantic — Text ===== */
    --text-color--text-primary: var(--base-color-neutral--black);
    --text-color--text-secondary: var(--base-color-neutral--black);
    --text-color--text-alternate: var(--base-color-neutral--white);
    --text-color--text-success: var(--base-color-system--success-green);
    --text-color--text-error: var(--base-color-system--error-red);

    /* ===== Semantic — Link ===== */
    --link-color--link-primary: var(--base-color-neutral--black);
    --link-color--link-secondary: var(--base-color-neutral--black);
    --link-color--link-alternate: var(--base-color-neutral--white);

    /* ===== Semantic — Border ===== */
    --border-color--border-primary: var(--base-color-neutral--black);
    --border-color--border-secondary: var(--base-color-neutral--neutral-light);
    --border-color--border-alternate: var(--base-color-neutral--white);

    /* ===== Short aliases (used by existing rc-* sections) ===== */
    --rc-green: #1e4433;
    --rc-green-hover: #264f3f;
    --rc-sage: #6c9985;
    --rc-yellow: #edb81e;
    --rc-beige: #e6e3de;
    --rc-off-white: #f6f6f6;
    --rc-off-black: #121212;
    --rc-white: #ffffff;
    --rc-black: #000000;
    --rc-orange: #E05A0C;

    /* Neutral aliases */
    --rc-neutral-lightest: #eeeeee;
    --rc-neutral-lighter: #cccccc;
    --rc-neutral-light: #aaaaaa;
    --rc-neutral: #666666;
    --rc-neutral-dark: #444444;
    --rc-neutral-darker: #222222;
    --rc-neutral-darkest: #111111;

    /* Semantic aliases */
    --rc-text: var(--rc-off-black);
    --rc-text-muted: var(--rc-neutral);
    --rc-bg-primary: var(--rc-white);
    --rc-bg-secondary: var(--rc-off-white);
    --rc-bg-alt: var(--rc-beige);
    --rc-border: var(--rc-neutral-light);

    /* Backwards-compat aliases */
    --rc-cream: var(--rc-off-white);
    --rc-cream-alt: var(--rc-beige);

    /* ===== Heading sizes ===== */
    --rc-h1: 56px;
    --rc-h2: 48px;
    --rc-h3: 40px;
    --rc-h4: 32px;
    --rc-h5: 24px;
    --rc-h6: 20px;

    /* ===== Heading weights ===== */
    --rc-heading-weight: 500;
    --rc-heading-weight-bold: 700;
    --rc-heading-lh: 1.2;

    /* ===== Body text ===== */
    --rc-text-base: 1rem;
    --rc-text-sm: 0.875rem;
    --rc-text-xs: 0.75rem;
    --rc-text-md: 1.125rem;
    --rc-text-lg: 1.25rem;
    --rc-body-lh: 1.5;
    --rc-body-weight: 400;

    /* ===== Layout ===== */
    --rc-max-width: 80rem;
    --rc-page-padding: 5%;

    /* ===== Section padding ===== */
    --rc-section-lg: 7rem;
    --rc-section-md: 5rem;
    --rc-section-sm: 3rem;
    --rc-section-pad: var(--rc-section-md);

    /* ===== Border radius ===== */
    --rc-radius: 8px;
    --rc-radius-sm: 4px;
    --rc-radius-lg: 12px;
  }

  /* ===== Global typography ===== */
  body, h1, h2, h3, h4, h5, h6, p, a, button, input, select, textarea {
    font-family: var(--rc-font);
  }

  [class^="rc-"], [class*=" rc-"] {
    font-family: var(--rc-font);
  }

  /* ===== Heading resets for rc-* sections ===== */
  [class^="rc-"] h1 { font-size: var(--rc-h1); font-weight: var(--rc-heading-weight); line-height: var(--rc-heading-lh); color: var(--rc-text); margin: 0; }
  [class^="rc-"] h2 { font-size: var(--rc-h2); font-weight: var(--rc-heading-weight); line-height: var(--rc-heading-lh); color: var(--rc-text); margin: 0; }
  [class^="rc-"] h3 { font-size: var(--rc-h3); font-weight: var(--rc-heading-weight); line-height: var(--rc-heading-lh); color: var(--rc-text); margin: 0; }
  [class^="rc-"] h4 { font-size: var(--rc-h4); font-weight: var(--rc-heading-weight); line-height: 1.3; color: var(--rc-text); margin: 0; }
  [class^="rc-"] h5 { font-size: var(--rc-h5); font-weight: var(--rc-heading-weight-bold); line-height: 1.4; color: var(--rc-text); margin: 0; }
  [class^="rc-"] h6 { font-size: var(--rc-h6); font-weight: var(--rc-heading-weight-bold); line-height: 1.4; color: var(--rc-text); margin: 0; }

  /* ===== Webflow heading utility classes ===== */
  .heading-style-h2 {
    font-family: var(--recarpet-dm-sans);
    color: var(--base-color-brand--rc-off-black);
    font-size: 48px;
    font-weight: 500;
    line-height: 120%;
  }

  .heading-style-h4 {
    font-family: var(--recarpet-dm-sans);
    color: var(--base-color-brand--rc-off-black);
    font-size: 32px;
    font-weight: 500;
    line-height: 130%;
  }
  .heading-style-h4.center { text-align: center; }
  .heading-style-h4.white,
  .heading-style-h4.center.white {
    color: var(--base-color-brand--white);
  }

  .heading-style-h5 {
    font-family: var(--recarpet-dm-sans);
    color: var(--base-color-brand--rc-off-black);
    font-size: 24px;
    font-weight: 700;
    line-height: 140%;
  }

  /* ===== Webflow text utility classes ===== */
  .text-size-medium {
    font-family: var(--recarpet-dm-sans);
    color: var(--base-color-brand--rc-off-black);
    font-size: 1.125rem;
    font-weight: 400;
  }

  .text-style-tagline {
    color: var(--base-color-brand--rc-off-black);
    justify-content: center;
    align-items: center;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
  }

  .text_menu {
    font-family: var(--recarpet-dm-sans);
    color: var(--base-color-brand--rc-off-black);
    font-size: 16px;
    line-height: 120%;
  }

  /* ===== Webflow button classes ===== */
  .button {
    border: 1px solid var(--base-color-brand--rc-re-green);
    background-color: var(--base-color-brand--rc-re-green);
    color: var(--base-color-neutral--white);
    text-align: center;
    border-radius: 8px;
    padding: .75rem 1.5rem;
    font-size: 1rem;
    text-decoration: none;
    font-family: var(--recarpet-dm-sans);
    font-weight: 400;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .button:hover {
    background-color: var(--rc-green-hover);
    border-color: var(--rc-green-hover);
    color: var(--base-color-neutral--white);
  }

  .button.is-secondary {
    color: var(--base-color-brand--rc-re-green);
    background-color: transparent;
  }
  .button.is-secondary:hover {
    background-color: var(--base-color-brand--rc-re-green);
    color: var(--base-color-neutral--white);
  }

  /* ===== rc-btn styles (existing sections) ===== */
  .rc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 0.75rem 1.5rem;
    font-family: var(--rc-font);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.4;
    text-decoration: none;
    border-radius: var(--rc-radius);
    border: 1px solid transparent;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .rc-btn--primary {
    background: var(--rc-green);
    color: var(--rc-white);
    border-color: var(--rc-green);
  }
  .rc-btn--primary:hover {
    background: var(--rc-green-hover);
    border-color: var(--rc-green-hover);
    color: var(--rc-white);
  }

  .rc-btn--outline {
    background: transparent;
    color: var(--rc-green);
    border-color: var(--rc-green);
  }
  .rc-btn--outline:hover {
    background: var(--rc-green);
    color: var(--rc-white);
  }

  .rc-btn--outline-white {
    background: transparent;
    color: var(--rc-white);
    border-color: rgba(255,255,255,0.85);
  }
  .rc-btn--outline-white:hover {
    background: rgba(255,255,255,0.15);
    color: var(--rc-white);
  }

  .rc-btn--sm {
    padding: 0.5rem 1.25rem;
    font-size: var(--rc-text-sm);
  }

  .rc-btn--link {
    padding: 0.25rem 0;
    background: transparent;
    border: none;
    color: var(--rc-green);
    line-height: 1;
  }

  /* ===== Layout utility ===== */
  .padding-global {
    padding-left: 5%;
    padding-right: 5%;
  }

  /* ===== Responsive breakpoints ===== */
  @media (max-width: 991px) {
    :root {
      --rc-section-lg: 6rem;
      --rc-section-md: 4rem;
    }
    .heading-style-h2 { font-size: 36px; }
    .heading-style-h4 { font-size: 26px; }
  }

  @media (max-width: 767px) {
    :root {
      --rc-section-lg: 4rem;
      --rc-section-md: 3rem;
      --rc-section-sm: 2rem;
    }
    .rc-btn, .button {
      padding: 0.625rem 1.25rem;
      font-size: 1rem;
    }
    .heading-style-h2 { font-size: 28px; }
    .heading-style-h4 { font-size: 22px; }
    .heading-style-h5 { font-size: 20px; }
  }
</style>
