<!-- reCarpet Mega Menu -->
<style>
  .mega-menu-container {
    position: relative;
    font-family: var(--rc-font, 'DM Sans', sans-serif);
    grid-area: navigation;
    display: none;
    margin-left: 2rem;
  }

  @media screen and (min-width: 990px) {
    .mega-menu-container {
      display: block;
    }
  }

  /* Nav list styling */
  .mega-menu-list {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  /* Individual nav link */
  .mega-menu-item {
    position: static;
  }

  /* Shared styling for both <button> and <a> nav links */
  .mega-menu-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 1rem 0;
    color: inherit;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    line-height: 1;
    transition: color 0.3s ease;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
  }

  a.mega-menu-link {
    padding: 1rem 0;
  }

  .mega-menu-link:hover {
    color: var(--rc-green, #1e4433);
  }

  /* Chevron icon — use SVG for consistency */
  .mega-menu-chevron {
    display: inline-flex;
    align-items: center;
    font-size: 0.65rem;
    transition: transform 0.3s ease;
  }

  .mega-menu-item.is-open .mega-menu-chevron {
    transform: rotate(180deg);
  }

  /* Dropdown panel — fixed full-width, semi-transparent */
  .mega-menu-panel {
    position: fixed;
    left: 0;
    right: 0;
    background: rgba(246, 246, 246, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(230, 227, 222, 0.6);
    border-bottom: 1px solid rgba(230, 227, 222, 0.6);
    padding: 2.5rem var(--rc-page-padding, 5%);
    min-height: auto;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 100;
    pointer-events: none;
  }

  .mega-menu-item.is-open .mega-menu-panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* Dropdown content wrapper — centered */
  .mega-menu-grid-wrapper {
    max-width: var(--rc-max-width, 80rem);
    margin: 0 auto;
    padding: 0 3rem;
  }

  /* Grid layout for dropdown items */
  .mega-menu-grid {
    display: grid;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Responsive grid columns based on menu section */
  .mega-menu-grid.columns-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .mega-menu-grid.columns-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .mega-menu-grid.columns-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .mega-menu-grid.columns-5 {
    grid-template-columns: repeat(5, 1fr);
  }

  .mega-menu-grid.columns-6 {
    grid-template-columns: repeat(6, 1fr);
  }

  /* Grid item (link with title + description) */
  .mega-menu-grid-item {
    display: flex;
    flex-direction: column;
  }

  .mega-menu-grid-link {
    text-decoration: none;
    color: inherit;
  }

  .mega-menu-grid-title {
    font-weight: 700;
    font-size: 1rem;
    color: var(--rc-off-black, #121212);
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
  }

  .mega-menu-grid-description {
    font-size: var(--rc-text-sm, 0.875rem);
    color: #666;
    margin: 0;
    line-height: 1.5;
  }

  .mega-menu-grid-link:hover .mega-menu-grid-title {
    color: var(--rc-green, #1e4433);
  }

  /* Responsive: hide panel on mobile */
  @media (max-width: 768px) {
    .mega-menu-panel {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      padding: 0;
      border: none;
      background: transparent;
      min-height: auto;
    }

    .mega-menu-grid {
      grid-template-columns: 1fr !important;
      gap: 1rem;
    }

    .mega-menu-list {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>

<nav class="mega-menu-container" role="navigation">
  {%- if linklists[section.settings.menu] -%}
    <ul class="mega-menu-list">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links != blank -%}
          <!-- Has dropdown -->
          <li class="mega-menu-item has-dropdown" data-menu-trigger="{{ link.handle }}">
            <button class="mega-menu-link" type="button" aria-expanded="false" aria-controls="menu-{{ link.handle }}">
              {{ link.title }}
              <span class="mega-menu-chevron">▾</span>
            </button>

            <div class="mega-menu-panel" id="menu-{{ link.handle }}" hidden>
              <div class="mega-menu-grid-wrapper">
                <ul class="mega-menu-grid columns-{{ link.links | size }}">
                  {%- for child_link in link.links -%}
                    {%- assign handle = child_link.handle -%}
                    {%- assign description = '' -%}
                    {%- case handle -%}
                      {%- when 'fastighetsagare' -%}
                        {%- assign description = 'Utforska våra tjänster och maximera återbruket' -%}
                      {%- when 'arkitekter' or 'arkitekt' -%}
                        {%- assign description = 'Utforska vårt sortiment och beställ prover' -%}
                      {%- when 'hyresgast' -%}
                        {%- assign description = 'Byt kontorsgolv enkelt med vår helhetslösning' -%}
                      {%- when 'entreprenor' or 'entreprenorer' -%}
                        {%- assign description = 'Upptäck hur våra mattor läggs enkelt och hållbart' -%}
                      {%- when 'inventering' -%}
                        {%- assign description = 'Inspektion och bedömning av era mattor' -%}
                      {%- when 'demontering' -%}
                        {%- assign description = 'Monterar bort och tvättar era befintliga mattor' -%}
                      {%- when 'formedling' -%}
                        {%- assign description = 'Säljer återbrukade och nya textilplattor' -%}
                      {%- when 'montering' -%}
                        {%- assign description = 'Vi utför själva montering av era nya mattor' -%}
                      {%- when 'service-underhall' -%}
                        {%- assign description = 'Vi underhåller era monterade mattor' -%}
                      {%- when 'internt-aterbruk' -%}
                        {%- assign description = 'Ge era befintliga golv nytt liv' -%}
                      {%- when 'aterbrukade-textilplattor' -%}
                        {%- assign description = 'Vårt eget sortiment av återbrukade kvalitetsmattor' -%}
                      {%- when 'nya-textilplattor' -%}
                        {%- assign description = 'Kompletterande sortiment av nya textilplattor från Milliken Floors' -%}
                    {%- endcase -%}
                    <li class="mega-menu-grid-item">
                      <a href="{{ child_link.url }}" class="mega-menu-grid-link">
                        <h3 class="mega-menu-grid-title">{{ child_link.title }}</h3>
                        {%- if description != blank -%}
                          <p class="mega-menu-grid-description">{{ description }}</p>
                        {%- endif -%}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            </div>
          </li>
        {%- else -%}
          <!-- No dropdown, plain link -->
          <li class="mega-menu-item">
            <a href="{{ link.url }}" class="mega-menu-link">
              {{ link.title }}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    <!-- Menu interaction script -->
    <script>
      (function() {
        const menuItems = document.querySelectorAll('.mega-menu-item.has-dropdown');
        let hoverTimeout;

        function positionPanel(panel) {
          const header = document.querySelector('.section-header');
          if (header) {
            const rect = header.getBoundingClientRect();
            panel.style.top = rect.bottom + 'px';
          }
        }

        function openMenu(item) {
          const trigger = item.querySelector('.mega-menu-link');
          const panel = item.querySelector('.mega-menu-panel');
          positionPanel(panel);
          item.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
          panel.removeAttribute('hidden');
        }

        function closeMenu(item) {
          const trigger = item.querySelector('.mega-menu-link');
          const panel = item.querySelector('.mega-menu-panel');
          item.classList.remove('is-open');
          trigger.setAttribute('aria-expanded', 'false');
          panel.setAttribute('hidden', '');
        }

        menuItems.forEach(item => {
          // Desktop hover behavior
          item.addEventListener('mouseenter', () => {
            clearTimeout(hoverTimeout);
            menuItems.forEach(other => { if (other !== item) closeMenu(other); });
            openMenu(item);
          });

          item.addEventListener('mouseleave', () => {
            hoverTimeout = setTimeout(() => closeMenu(item), 150);
          });

          // Keep panel open when hovering it
          const panel = item.querySelector('.mega-menu-panel');
          if (panel) {
            panel.addEventListener('mouseenter', () => clearTimeout(hoverTimeout));
            panel.addEventListener('mouseleave', () => {
              hoverTimeout = setTimeout(() => closeMenu(item), 150);
            });
          }

          // Click behavior for mobile/touch
          item.querySelector('.mega-menu-link').addEventListener('click', (e) => {
            e.preventDefault();
            const isOpen = item.classList.contains('is-open');
            menuItems.forEach(other => closeMenu(other));
            if (!isOpen) openMenu(item);
          });
        });

        // Close menus when clicking outside
        document.addEventListener('click', (e) => {
          if (!e.target.closest('.mega-menu-container') && !e.target.closest('.mega-menu-panel')) {
            menuItems.forEach(item => closeMenu(item));
          }
        });
      })();
    </script>

    {%- endif -%}
</nav>