{%- comment -%}
  reCarpet — Product Specs Panel
  Renders the technical specifications table and order info
  for ORAK / Composil / Milliken products.

  All data comes from product.metafields.recarpet.*
  Fields that are empty are simply not rendered.

  Usage: {% render 'recarpet-product-specs', product: product %}
{%- endcomment -%}

{%- comment -%} Skip rendering for service products (ej fysiska produkter) {%- endcomment -%}
{%- assign _spec_sku = product.selected_or_first_available_variant.sku | default: '' -%}
{%- unless product.product_type contains 'Tjänst' or _spec_sku contains 'RC-SERVICE' -%}

{%- liquid
  assign mf           = product.metafields.recarpet
  assign dimensions   = mf.dimensions.value
  assign tech_url     = mf.technical_sheet_url.value
  assign product_label = mf.product_label.value
  assign backing      = mf.backing.value
  assign thickness    = mf.thickness.value
  assign fire_rating  = mf.fire_rating.value
  assign acoustic     = mf.acoustic_rating.value
  assign impact       = mf.impact_absorption.value
  assign lrv          = mf.lrv.value
  assign min_order    = mf.min_order.value
  assign delivery_days = mf.delivery_days.value
  assign pose_service = mf.pose_service.value
  assign maintenance  = mf.maintenance_service.value

  assign qty          = product.selected_or_first_available_variant.inventory_quantity
  assign in_stock     = false
  if qty > 0
    assign in_stock = true
  endif
-%}

<div class="recarpet-specs">

  {%- comment -%} ── Stock badge + Product label ─────────────────────────── {%- endcomment -%}
  <div class="recarpet-specs__badges">
    {%- if in_stock -%}
      <span class="recarpet-badge recarpet-badge--stock">IN STOCK</span>
    {%- else -%}
      <span class="recarpet-badge recarpet-badge--outofstock">OUT OF STOCK</span>
    {%- endif -%}
    {%- if product_label != blank -%}
      {%- liquid
        assign label_display = product_label | downcase
        case label_display
          when 'réemploi'
            assign label_display = 'Återbruk'
          when 'reemploi'
            assign label_display = 'Återbruk'
          when 'fin de série'
            assign label_display = 'Slutsåld kollektion'
          when 'fin de serie'
            assign label_display = 'Slutsåld kollektion'
          when 'produit à venir'
            assign label_display = 'Kommer snart'
          else
            assign label_display = product_label
        endcase
      -%}
      <span class="recarpet-badge recarpet-badge--label">{{ label_display | upcase }}</span>
    {%- endif -%}
  </div>

  {%- comment -%} ── Services (Pose / Maintenance) ──────────────────────── {%- endcomment -%}
  {%- if pose_service != blank or maintenance != blank -%}
    <div class="recarpet-specs__services">
      {%- if pose_service != blank -%}
        <div class="recarpet-service">
          <span class="recarpet-service__icon">
            {%- render 'icon-install' -%}
          </span>
          <div>
            <span class="recarpet-service__label">INSTALLATION</span>
            <span class="recarpet-service__value">{{ pose_service }}</span>
          </div>
        </div>
      {%- endif -%}
      {%- if maintenance != blank -%}
        <div class="recarpet-service">
          <span class="recarpet-service__icon">
            {%- render 'icon-maintenance' -%}
          </span>
          <div>
            <span class="recarpet-service__label">MAINTENANCE</span>
            <span class="recarpet-service__value">{{ maintenance }}</span>
          </div>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Technical specs table ─────────────────────────────── {%- endcomment -%}
  {%- assign has_specs = false -%}
  {%- if backing != blank or dimensions != blank or thickness != blank or fire_rating != blank or acoustic != blank or impact != blank or lrv != blank or tech_url != blank -%}
    {%- assign has_specs = true -%}
  {%- endif -%}

  {%- if has_specs -%}
    <table class="recarpet-specs__table">
      {%- if backing != blank -%}
        <tr>
          <td class="recarpet-specs__label">Backing</td>
          <td class="recarpet-specs__value">{{ backing }}</td>
        </tr>
      {%- endif -%}
      {%- if dimensions != blank -%}
        <tr>
          <td class="recarpet-specs__label">Format</td>
          <td class="recarpet-specs__value">{{ dimensions }} cm</td>
        </tr>
      {%- endif -%}
      {%- if thickness != blank -%}
        <tr>
          <td class="recarpet-specs__label">Thickness</td>
          <td class="recarpet-specs__value">{{ thickness }}</td>
        </tr>
      {%- endif -%}
      {%- if fire_rating != blank -%}
        <tr>
          <td class="recarpet-specs__label">Fire rating</td>
          <td class="recarpet-specs__value">{{ fire_rating }}</td>
        </tr>
      {%- endif -%}
      {%- if acoustic != blank -%}
        <tr>
          <td class="recarpet-specs__label">Sound insulation</td>
          <td class="recarpet-specs__value">{{ acoustic }}</td>
        </tr>
      {%- endif -%}
      {%- if impact != blank -%}
        <tr>
          <td class="recarpet-specs__label">Impact absorption</td>
          <td class="recarpet-specs__value">{{ impact }}</td>
        </tr>
      {%- endif -%}
      {%- if lrv != blank -%}
        <tr>
          <td class="recarpet-specs__label">LRV</td>
          <td class="recarpet-specs__value">{{ lrv }}</td>
        </tr>
      {%- endif -%}
      {%- if tech_url != blank -%}
        <tr>
          <td class="recarpet-specs__label">Technical sheet</td>
          <td class="recarpet-specs__value">
            <a href="{{ tech_url }}" target="_blank" rel="noopener" class="recarpet-specs__pdf-link">
              Download PDF
            </a>
          </td>
        </tr>
      {%- endif -%}
    </table>
  {%- endif -%}

  {%- comment -%} ── Order info bar ────────────────────────────────────── {%- endcomment -%}
  {%- if qty > 0 or min_order != blank or delivery_days != blank -%}
    <div class="recarpet-specs__order-bar">
      {%- if qty > 0 -%}
        <div class="recarpet-specs__order-cell">
          <span class="recarpet-specs__order-label">In stock</span>
          <span class="recarpet-specs__order-value">{{ qty }} m²</span>
        </div>
      {%- endif -%}
      {%- if min_order != blank -%}
        <div class="recarpet-specs__order-cell">
          <span class="recarpet-specs__order-label">Min. order</span>
          <span class="recarpet-specs__order-value">{{ min_order }}</span>
        </div>
      {%- endif -%}
      {%- if delivery_days != blank -%}
        <div class="recarpet-specs__order-cell">
          <span class="recarpet-specs__order-label">Lead time</span>
          <span class="recarpet-specs__order-value">{{ delivery_days }} days</span>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Stock disclaimer for Orak / Composil (non-realtime inventory) ── {%- endcomment -%}
  {%- if _spec_sku contains 'RC-ORAK' or _spec_sku contains 'RC-COMP' -%}
    <div class="recarpet-specs__disclaimer">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span>Lagerstatus uppdateras periodvis och kan avvika från faktiskt lager. Kontakta oss för att säkerställa tillgänglighet.</span>
    </div>
  {%- endif -%}

  {%- comment -%} ── Sample request CTA — Milliken products only ────────── {%- endcomment -%}
  {%- if _spec_sku contains 'Milliken' -%}
    <div class="recarpet-sample-cta">
      <div class="recarpet-sample-cta__inner">
        <div class="recarpet-sample-cta__text">
          <strong>Beställ prov</strong>
          <span>Vill du se och känna på materialet innan du beställer?</span>
        </div>
        <button type="button" class="recarpet-sample-cta__btn" onclick="document.getElementById('recarpet-sample-modal').showModal()">
          Kontakta oss
        </button>
      </div>
    </div>

    <dialog id="recarpet-sample-modal" class="recarpet-sample-modal">
      <form method="dialog" class="recarpet-sample-modal__close-wrapper">
        <button type="submit" class="recarpet-sample-modal__close" aria-label="Stäng">&times;</button>
      </form>
      <div class="recarpet-sample-modal__content">
        <h3 class="recarpet-sample-modal__title">Beställ produktprov</h3>
        <p class="recarpet-sample-modal__subtitle">Fyll i dina uppgifter så återkommer vi med provleverans.</p>

        <form id="recarpet-sample-form" class="recarpet-sample-modal__form">
          <input type="hidden" name="product_sku" value="{{ _spec_sku }}">
          <input type="hidden" name="product_title" value="{{ product.title | escape }}">

          <label class="recarpet-sample-modal__label">
            Namn
            <input type="text" name="name" required class="recarpet-sample-modal__input"
              {%- if customer %} value="{{ customer.name | escape }}"{% endif %}>
          </label>

          <label class="recarpet-sample-modal__label">
            E-post
            <input type="email" name="email" required class="recarpet-sample-modal__input"
              {%- if customer %} value="{{ customer.email | escape }}"{% endif %}>
          </label>

          <label class="recarpet-sample-modal__label">
            Telefon
            <input type="tel" name="phone" class="recarpet-sample-modal__input"
              {%- if customer.phone %} value="{{ customer.phone | escape }}"{% endif %}>
          </label>

          <label class="recarpet-sample-modal__label">
            Meddelande
            <textarea name="message" rows="3" class="recarpet-sample-modal__textarea">Hej, jag vill gärna beställa ett prov av {{ product.title | escape }} (SKU: {{ _spec_sku }}).
            </textarea>
          </label>

          <button type="submit" class="recarpet-sample-modal__submit">Skicka förfrågan</button>
        </form>

        <div id="recarpet-sample-success" class="recarpet-sample-modal__success" style="display:none;">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1a6b2f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <p><strong>Tack för din förfrågan!</strong></p>
          <p>Vi återkommer till dig inom kort angående provleverans.</p>
        </div>
      </div>
    </dialog>

    <script>
    (function() {
      var form = document.getElementById('recarpet-sample-form');
      if (!form) return;

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var data = new FormData(form);

        // Send via Shopify contact form endpoint
        fetch('/contact#contact_form', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({
            'form_type': 'contact',
            'utf8': '\u2713',
            'contact[name]': data.get('name'),
            'contact[email]': data.get('email'),
            'contact[phone]': data.get('phone') || '',
            'contact[body]': '[PROVBESTÄLLNING] Produkt: ' + data.get('product_title') + ' (SKU: ' + data.get('product_sku') + ')\n\n' + data.get('message'),
          }),
        }).then(function() {
          form.style.display = 'none';
          document.getElementById('recarpet-sample-success').style.display = 'block';
          setTimeout(function() {
            var modal = document.getElementById('recarpet-sample-modal');
            if (modal && modal.close) modal.close();
            // Reset for next use
            form.style.display = '';
            document.getElementById('recarpet-sample-success').style.display = 'none';
            form.reset();
          }, 3000);
        }).catch(function() {
          alert('Något gick fel. Försök igen eller kontakta oss direkt på info@recarpet.se.');
        });
      });
    })();
    </script>
  {%- endif -%}

</div>

<style>
  .recarpet-specs {
    margin: 20px 0;
    font-family: inherit;
  }

  /* Badges */
  .recarpet-specs__badges {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .recarpet-badge {
    display: inline-block;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    border-radius: 3px;
    text-transform: uppercase;
  }
  .recarpet-badge--stock {
    background: #e6f4ea;
    color: #1a6b2f;
    border: 1px solid #a8d5b5;
  }
  .recarpet-badge--outofstock {
    background: #f5f5f5;
    color: #888;
    border: 1px solid #ddd;
  }
  .recarpet-badge--label {
    background: #f5f0e8;
    color: #7a5c2e;
    border: 1px solid #e0d0b8;
  }

  /* Services */
  .recarpet-specs__services {
    display: flex;
    gap: 24px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .recarpet-service {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .recarpet-service__icon {
    width: 36px;
    height: 36px;
    background: #f5f0c8;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .recarpet-service__label {
    display: block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #999;
    text-transform: uppercase;
    text-decoration: underline;
  }
  .recarpet-service__value {
    display: block;
    font-size: 14px;
    color: #222;
  }

  /* Specs table */
  .recarpet-specs__table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
    font-size: 14px;
  }
  .recarpet-specs__table tr {
    border-bottom: 1px solid #eee;
  }
  .recarpet-specs__table tr:last-child {
    border-bottom: none;
  }
  .recarpet-specs__label {
    padding: 10px 0;
    color: #666;
    width: 50%;
    vertical-align: top;
  }
  .recarpet-specs__value {
    padding: 10px 0;
    color: #111;
    font-weight: 400;
  }
  .recarpet-specs__pdf-link {
    color: #111;
    text-decoration: underline;
  }

  /* Order bar */
  .recarpet-specs__order-bar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    border: 1px solid #ddd;
    border-radius: 4px;
    overflow: hidden;
    margin-top: 4px;
  }
  .recarpet-specs__order-cell {
    padding: 14px 16px;
    text-align: center;
    border-right: 1px solid #ddd;
  }
  .recarpet-specs__order-cell:last-child {
    border-right: none;
  }
  .recarpet-specs__order-label {
    display: block;
    font-size: 11px;
    color: #888;
    margin-bottom: 4px;
  }
  .recarpet-specs__order-value {
    display: block;
    font-size: 16px;
    font-weight: 500;
    color: #111;
  }

  /* Stock disclaimer for non-realtime inventory */
  .recarpet-specs__disclaimer {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-top: 14px;
    padding: 10px 14px;
    background: #fdf6e3;
    border: 1px solid #e8d5a3;
    border-radius: 4px;
    font-size: 13px;
    line-height: 1.5;
    color: #7a5c2e;
  }
  .recarpet-specs__disclaimer svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: #b8860b;
  }

  /* ── Sample request CTA (Milliken only) ──────────────── */
  .recarpet-sample-cta {
    margin-top: 18px;
  }
  .recarpet-sample-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 20px;
    background: #f5f5f0;
    border: 1px solid #ddd;
    border-radius: 4px;
  }
  .recarpet-sample-cta__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .recarpet-sample-cta__text strong {
    font-size: 15px;
    color: #111;
  }
  .recarpet-sample-cta__text span {
    font-size: 13px;
    color: #666;
  }
  .recarpet-sample-cta__btn {
    flex-shrink: 0;
    padding: 10px 24px;
    background: #1e4433;
    color: #fff;
    border: none;
    border-radius: 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .recarpet-sample-cta__btn:hover {
    background: #264f3f;
  }
  @media (max-width: 480px) {
    .recarpet-sample-cta__inner {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }
  }

  /* ── Sample request modal ────────────────────────────── */
  .recarpet-sample-modal {
    border: none;
    border-radius: 8px;
    padding: 0;
    max-width: 460px;
    width: 90vw;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  }
  .recarpet-sample-modal::backdrop {
    background: rgba(0,0,0,0.45);
  }
  .recarpet-sample-modal__close-wrapper {
    display: flex;
    justify-content: flex-end;
    padding: 12px 16px 0;
  }
  .recarpet-sample-modal__close {
    background: none;
    border: none;
    font-size: 28px;
    color: #999;
    cursor: pointer;
    line-height: 1;
    padding: 0 4px;
  }
  .recarpet-sample-modal__close:hover {
    color: #333;
  }
  .recarpet-sample-modal__content {
    padding: 0 28px 28px;
  }
  .recarpet-sample-modal__title {
    font-family: 'DM Sans', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #111;
    margin: 0 0 4px;
  }
  .recarpet-sample-modal__subtitle {
    font-size: 14px;
    color: #666;
    margin: 0 0 20px;
  }
  .recarpet-sample-modal__form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .recarpet-sample-modal__label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 13px;
    font-weight: 500;
    color: #333;
  }
  .recarpet-sample-modal__input,
  .recarpet-sample-modal__textarea {
    padding: 10px 12px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: inherit;
    font-size: 14px;
    color: #111;
    background: #fff;
    transition: border-color 0.2s;
  }
  .recarpet-sample-modal__input:focus,
  .recarpet-sample-modal__textarea:focus {
    outline: none;
    border-color: #1e4433;
  }
  .recarpet-sample-modal__textarea {
    resize: vertical;
    min-height: 70px;
  }
  .recarpet-sample-modal__submit {
    padding: 12px 24px;
    background: #1e4433;
    color: #fff;
    border: none;
    border-radius: 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 4px;
  }
  .recarpet-sample-modal__submit:hover {
    background: #264f3f;
  }
  .recarpet-sample-modal__success {
    text-align: center;
    padding: 20px 0;
  }
  .recarpet-sample-modal__success p {
    margin: 8px 0 0;
    font-size: 14px;
    color: #333;
  }
</style>

{%- endunless -%}
